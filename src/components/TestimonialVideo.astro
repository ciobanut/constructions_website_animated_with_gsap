---
// src/components/TestimonialVideo.astro
// Testimonial section — boxed YouTube video with title above
---

<section id="testimonial" class="testimonial-section">
  <div class="container">
    <h2 class="testimonial-title">
      ConstIQ created<br>
      something better than I ever<br>
      could have imagined
    </h2>

    <div class="video-box">
      <iframe
        src="https://www.youtube.com/embed/07V-FfsUUYk?controls=1&rel=0&modestbranding=1&enablejsapi=1"
        allow="encrypted-media"
        allowfullscreen></iframe>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.from(".testimonial-title", {
    y: 40,
    opacity: 0,
    duration: 0.8,
    ease: "power3.out",
    scrollTrigger: {
      trigger: ".testimonial-section",
      start: "top 80%",
      end: "top 50%",
      toggleActions: "play none none reverse",
    },
  });

  gsap.from(".video-box", {
    y: 50,
    opacity: 0,
    duration: 1,
    delay: 0.2,
    ease: "power3.out",
    scrollTrigger: {
      trigger: ".testimonial-section",
      start: "top 80%",
      end: "top 50%",
      toggleActions: "play none none reverse",
    },
  });
</script>

<style>
  .testimonial-section {
    width: 100%;
    padding: 5rem 2rem 6rem;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  .testimonial-title {
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: 0.03em;
    margin: 0 0 3rem;
    text-align: left;
  }

  .video-box {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
  }

  .video-box iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  @media (max-width: 767px) {
    .testimonial-section {
      padding: 3rem 1.25rem 4rem;
    }

    .testimonial-title {
      margin-bottom: 2rem;
    }
  }
</style>
