---
// src/components/TestimonialVideo.astro
// Full-viewport pinned testimonial panels with scroll-driven scale/fade exit
---

<section id="testimonial" class="testimonial-section">
  <!-- Panel 1 — original title -->
  <div class="video-card" data-testimonial>
    <div class="video-card-inner">
      <h2 class="panel-title">
        ConstIQ created<br />
        something better than I ever<br />
        could have imagined
      </h2>
      <div class="testimonial-card">
        <blockquote class="testimonial-quote">
          “Prominent's design and attention to detail exceeded every expectation. A professional team that delivers on time and at the highest standards.”
        </blockquote>
        <div class="testimonial-author">
          <span class="testimonial-name">Haci Shahab</span>
          <span class="testimonial-role">Client, Dream City Villa</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Panel 2 -->
  <div class="video-card" data-testimonial>
    <div class="video-card-inner">
      <h2 class="panel-title">
        Precision in Every<br />
        Project We Deliver
      </h2>
      <div class="testimonial-card">
        <blockquote class="testimonial-quote">
          “We have collaborated on multiple projects, and every time the result has been excellent. Their precision execution makes all the difference.”
        </blockquote>
        <div class="testimonial-author">
          <span class="testimonial-name">Haci Idris &amp; Lokman</span>
          <span class="testimonial-role">Clients, Private Villa Project</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Panel 3 -->
  <div class="video-card" data-testimonial>
    <div class="video-card-inner">
      <h2 class="panel-title">
        Building the Future<br />
        With Every Brick
      </h2>
      <div class="testimonial-card">
        <blockquote class="testimonial-quote">
          “Professionalism, quality, and timeliness — exactly what we were looking for in a construction partner. Our project was delivered flawlessly.”
        </blockquote>
        <div class="testimonial-author">
          <span class="testimonial-name">Dream City Residence</span>
          <span class="testimonial-role">Commercial Development</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Panel 4 -->
  <div class="video-card" data-testimonial>
    <div class="video-card-inner">
      <h2 class="panel-title">
        Trust Built<br />
        Over Generations
      </h2>
      <div class="testimonial-card">
        <blockquote class="testimonial-quote">
          “A team that truly understands the client's vision and brings it to life without compromise. Building trust with every project.”
        </blockquote>
        <div class="testimonial-author">
          <span class="testimonial-name">White House Project</span>
          <span class="testimonial-role">Turnkey Completion, Dream City</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  (function initVideoPanels() {
    const section = document.querySelector("#testimonial");
    const panels = gsap.utils.toArray("[data-testimonial]");

    if (!panels.length || !section) return;

    // ── Entrance animation for the first panel title ──
    const firstTitle = panels[0]?.querySelector(".panel-title");
    if (firstTitle) {
      gsap.from(firstTitle, {
        y: 40,
        opacity: 0,
        duration: 0.8,
        ease: "power3.out",
        scrollTrigger: {
          trigger: section,
          start: "top 80%",
          end: "top 50%",
          toggleActions: "play none none reverse",
        },
      });
    }

    // ── prefers-reduced-motion: skip all pin/scrub logic ──
    const mm = gsap.matchMedia();
    mm.add("(prefers-reduced-motion: no-preference)", () => {
      // Clone array; last panel is never pinned
      const pinPanels = [...panels];
      const last = pinPanels.pop();

      pinPanels.forEach((panel) => {
        const inner = panel.querySelector(".video-card-inner");
        if (!inner) return;

        const panelEl = panel;

        // Measure content height vs viewport
        const windowHeight = window.innerHeight;
        const panelHeight = inner.offsetHeight;
        const difference = panelHeight - windowHeight;

        // Ratio of total animation spent on "fake-scrolling" tall content
        const fakeScrollRatio =
          difference > 0
            ? difference / (difference + windowHeight)
            : 0;

        // Add bottom margin so the next panel doesn't overlap
        if (fakeScrollRatio) {
          panelEl.style.marginBottom =
            panelHeight * fakeScrollRatio + "px";
        }

        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: panelEl,
            start: "bottom bottom",
            end: () =>
              fakeScrollRatio
                ? `+=${inner.offsetHeight}`
                : "bottom top",
            pin: true,
            pinSpacing: false,
            scrub: true,
            invalidateOnRefresh: true,
          },
        });

        // ── Fake scroll for tall content ──
        if (fakeScrollRatio) {
          tl.to(inner, {
            yPercent: -100,
            y: window.innerHeight,
            duration: 1 / (1 - fakeScrollRatio) - 1,
            ease: "none",
          });
        }

        // ── Exit: scale down + fade out (0.9 / 0.1 split) ──
        tl.fromTo(
          panelEl,
          { scale: 1, opacity: 1 },
          { scale: 0.7, opacity: 0.5, duration: 0.9, ease: "power2.in" },
        ).to(panelEl, { opacity: 0, duration: 0.1, ease: "power2.in" });
      });

      // Cleanup on matchMedia reversion
      return () => {
        ScrollTrigger.getAll().forEach((st) => st.kill());
      };
    });
  })();
</script>

<style>
  .testimonial-section {
    width: 100%;
    position: relative;
    background: #0c0c0c;
  }

  .panel-title {
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: 0.03em;
    margin: 0 0 1.5rem;
    text-align: center;
    color: #f3f4f6;
  }

  /* ───────── Panel (full viewport) ───────── */
  .video-card {
    width: 100vw;
    height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
    will-change: transform, opacity;
    background: #0c0c0c;
  }

  .video-card-inner {
    max-width: 900px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }


  /* ───────── Testimonial text cards ───────── */
  .testimonial-card {
    width: 100%;
    max-width: 720px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .testimonial-quote {
    font-family: "Barlow", sans-serif;
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    font-weight: 300;
    line-height: 1.7;
    color: #d1d5db;
    font-style: italic;
    margin: 0;
    position: relative;
  }

  .testimonial-quote::before {
    content: "\201C";
    display: block;
    font-size: 4rem;
    line-height: 1;
    color: #ef4444;
    font-family: serif;
    margin-bottom: -0.75rem;
  }

  .testimonial-author {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .testimonial-name {
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    font-weight: 600;
    color: #f3f4f6;
    letter-spacing: 0.04em;
  }

  .testimonial-role {
    font-family: "Barlow", sans-serif;
    font-size: clamp(0.8rem, 1.2vw, 0.95rem);
    font-weight: 300;
    color: #9ca3af;
  }

  /* ───────── Responsive ───────── */
  @media (max-width: 767px) {
    .panel-title {
      margin-bottom: 1rem;
    }

    .video-card {
      padding: 1rem;
    }

    .video-card-inner {
      gap: 1rem;
    }

    .testimonial-card {
      gap: 1rem;
    }

    .testimonial-quote::before {
      font-size: 3rem;
    }
  }
</style>
