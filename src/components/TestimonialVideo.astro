---
// src/components/TestimonialVideo.astro
// Horizontally scrollable testimonial video slider
---

<section id="testimonial" class="testimonial-section">
  <div class="max-w-7xl mx-auto">
    <h2 class="testimonial-title">
      ConstIQ created<br />
      something better than I ever<br />
      could have imagined
    </h2>
  </div>

  <div class="scroll-wrapper">
    <div class="scroll-track">
      <!-- Slide 1 — real video -->
      <div class="video-card">
        <div class="video-box">
          <iframe
            src="https://www.youtube.com/embed/07V-FfsUUYk?controls=1&rel=0&modestbranding=1&enablejsapi=1"
            allow="encrypted-media"
            allowfullscreen></iframe>
        </div>
      </div>

      <!-- Slide 2 — placeholder -->
      <div class="video-card placeholder">
        <div class="video-box">
          <div class="placeholder-content">
            <svg
              class="play-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polygon points="5 3 19 12 5 21 5 3"></polygon>
            </svg>
            <span class="placeholder-label">Testimonial 2</span>
          </div>
        </div>
      </div>

      <!-- Slide 3 — placeholder -->
      <div class="video-card placeholder">
        <div class="video-box">
          <div class="placeholder-content">
            <svg
              class="play-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polygon points="5 3 19 12 5 21 5 3"></polygon>
            </svg>
            <span class="placeholder-label">Testimonial 3</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <p class="scroll-hint">Scroll →</p>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.from(".testimonial-title", {
    y: 40,
    opacity: 0,
    duration: 0.8,
    ease: "power3.out",
    scrollTrigger: {
      trigger: ".testimonial-section",
      start: "top 80%",
      end: "top 50%",
      toggleActions: "play none none reverse",
    },
  });

  gsap.from(".video-card", {
    y: 60,
    opacity: 0,
    duration: 0.8,
    stagger: 0.15,
    ease: "power3.out",
    scrollTrigger: {
      trigger: ".testimonial-section",
      start: "top 80%",
      end: "top 50%",
      toggleActions: "play none none reverse",
    },
  });
</script>

<style>
  .testimonial-section {
    width: 100%;
    padding: 5rem 0 6rem;
  }

  .testimonial-title {
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: 0.03em;
    margin: 0 0 3rem;
    padding: 0 2rem;
    text-align: left;
  }

  /* --- Horizontal scroll — full width --- */
  .scroll-wrapper {
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 1rem;
    scrollbar-width: thin;
  }

  .scroll-wrapper::-webkit-scrollbar {
    height: 6px;
  }

  .scroll-wrapper::-webkit-scrollbar-track {
    background: #e5e5e5;
    border-radius: 3px;
  }

  .scroll-wrapper::-webkit-scrollbar-thumb {
    background: #a0a0a0;
    border-radius: 3px;
  }

  .scroll-track {
    display: flex;
    gap: 2rem;
    width: max-content;
    padding: 0.5rem 2rem;
  }

  .video-card {
    width: clamp(300px, 70vw, 780px);
    scroll-snap-align: start;
    flex-shrink: 0;
  }

  .video-box {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
    background: #000;
  }

  .video-box iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* --- Placeholder styling --- */
  .video-card.placeholder .video-box {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    color: rgba(255, 255, 255, 0.7);
  }

  .play-icon {
    width: 56px;
    height: 56px;
    opacity: 0.5;
  }

  .placeholder-label {
    font-family: "Barlow", sans-serif;
    font-size: 1.1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* --- Scroll hint --- */
  .scroll-hint {
    font-family: "Barlow", sans-serif;
    font-size: 0.85rem;
    color: #888;
    text-align: right;
    margin: 1rem 0 0;
    padding: 0 2rem;
    letter-spacing: 0.05em;
    animation: pulse-hint 2s ease-in-out infinite;
  }

  @keyframes pulse-hint {
    0%,
    100% {
      opacity: 0.4;
    }
    50% {
      opacity: 1;
    }
  }

  @media (max-width: 767px) {
    .testimonial-section {
      padding: 3rem 0 4rem;
    }

    .testimonial-title {
      margin-bottom: 2rem;
    }

    .video-card {
      width: 85vw;
    }

    .scroll-track {
      gap: 1.25rem;
    }
  }
</style>
