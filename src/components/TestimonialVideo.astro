---
// src/components/TestimonialVideo.astro
// Full-viewport pinned video panels with scroll-driven scale/fade exit
---

<section id="testimonial" class="testimonial-section">
  <!-- Panel 1 — original title -->
  <div class="video-card" data-testimonial>
    <div class="video-card-inner">
      <h2 class="panel-title">
        ConstIQ created<br />
        something better than I ever<br />
        could have imagined
      </h2>
      <div class="video-box">
        <iframe
          src="https://www.youtube.com/embed/07V-FfsUUYk?controls=1&rel=0&modestbranding=1&enablejsapi=1"
          allow="encrypted-media"
          allowfullscreen></iframe>
      </div>
    </div>
  </div>

  <!-- Panel 2 -->
  <div class="video-card" data-testimonial>
    <div class="video-card-inner">
      <h2 class="panel-title">
        Precision in Every<br />
        Project We Deliver
      </h2>
      <div class="video-box">
        <iframe
          src="https://www.youtube.com/embed/Jw7s42Op2ao?controls=1&rel=0&modestbranding=1&enablejsapi=1"
          allow="encrypted-media"
          allowfullscreen></iframe>
      </div>
    </div>
  </div>

  <!-- Panel 3 -->
  <div class="video-card" data-testimonial>
    <div class="video-card-inner">
      <h2 class="panel-title">
        Building the Future<br />
        With Every Brick
      </h2>
      <div class="video-box">
        <iframe
          src="https://www.youtube.com/embed/zSk4kT8IMbQ?controls=1&rel=0&modestbranding=1&enablejsapi=1"
          allow="encrypted-media"
          allowfullscreen></iframe>
      </div>
    </div>
  </div>

  <!-- Panel 4 -->
  <div class="video-card" data-testimonial>
    <div class="video-card-inner">
      <h2 class="panel-title">
        Trust Built<br />
        Over Generations
      </h2>
      <div class="video-box">
        <iframe
          src="https://www.youtube.com/embed/YVQ2WA0SBMM?controls=1&rel=0&modestbranding=1&enablejsapi=1"
          allow="encrypted-media"
          allowfullscreen></iframe>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  (function initVideoPanels() {
    const section = document.querySelector("#testimonial");
    const panels = gsap.utils.toArray("[data-testimonial]");

    if (!panels.length || !section) return;

    // ── Entrance animation for the first panel title ──
    const firstTitle = panels[0]?.querySelector(".panel-title");
    if (firstTitle) {
      gsap.from(firstTitle, {
        y: 40,
        opacity: 0,
        duration: 0.8,
        ease: "power3.out",
        scrollTrigger: {
          trigger: section,
          start: "top 80%",
          end: "top 50%",
          toggleActions: "play none none reverse",
        },
      });
    }

    // ── prefers-reduced-motion: skip all pin/scrub logic ──
    const mm = gsap.matchMedia();
    mm.add("(prefers-reduced-motion: no-preference)", () => {
      // Clone array; last panel is never pinned
      const pinPanels = [...panels];
      const last = pinPanels.pop();

      pinPanels.forEach((panel) => {
        const inner = panel.querySelector(".video-card-inner");
        if (!inner) return;

        const panelEl = panel;

        // Measure content height vs viewport
        const windowHeight = window.innerHeight;
        const panelHeight = inner.offsetHeight;
        const difference = panelHeight - windowHeight;

        // Ratio of total animation spent on "fake-scrolling" tall content
        const fakeScrollRatio =
          difference > 0
            ? difference / (difference + windowHeight)
            : 0;

        // Add bottom margin so the next panel doesn't overlap
        if (fakeScrollRatio) {
          panelEl.style.marginBottom =
            panelHeight * fakeScrollRatio + "px";
        }

        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: panelEl,
            start: "bottom bottom",
            end: () =>
              fakeScrollRatio
                ? `+=${inner.offsetHeight}`
                : "bottom top",
            pin: true,
            pinSpacing: false,
            scrub: true,
            invalidateOnRefresh: true,
          },
        });

        // ── Fake scroll for tall content ──
        if (fakeScrollRatio) {
          tl.to(inner, {
            yPercent: -100,
            y: window.innerHeight,
            duration: 1 / (1 - fakeScrollRatio) - 1,
            ease: "none",
          });
        }

        // ── Exit: scale down + fade out (0.9 / 0.1 split) ──
        tl.fromTo(
          panelEl,
          { scale: 1, opacity: 1 },
          { scale: 0.7, opacity: 0.5, duration: 0.9, ease: "power2.in" },
        ).to(panelEl, { opacity: 0, duration: 0.1, ease: "power2.in" });
      });

      // Cleanup on matchMedia reversion
      return () => {
        ScrollTrigger.getAll().forEach((st) => st.kill());
      };
    });
  })();
</script>

<style>
  .testimonial-section {
    width: 100%;
    position: relative;
    background: #0c0c0c;
  }

  .panel-title {
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: 0.03em;
    margin: 0 0 1.5rem;
    text-align: center;
    color: #f3f4f6;
  }

  /* ───────── Panel (full viewport) ───────── */
  .video-card {
    width: 100vw;
    height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
    will-change: transform, opacity;
    background: #0c0c0c;
  }

  .video-card-inner {
    max-width: 900px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .video-box {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
    background: #000;
  }

  .video-box iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* ───────── Responsive ───────── */
  @media (max-width: 767px) {
    .panel-title {
      margin-bottom: 1rem;
    }

    .video-card {
      padding: 1rem;
    }

    .video-card-inner {
      gap: 1rem;
    }
  }
</style>
