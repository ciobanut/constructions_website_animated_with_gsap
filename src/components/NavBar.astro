---
const links = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Projects", href: "/#projects" },
  { label: "Services", href: "/#services-section" },
  { label: "Careers", href: "/careers" },
  { label: "Contact", href: "/contact" },
];
---

<nav class="navbar" id="navbar">
  <div class="nav-inner">
    <a href="/" class="logo">
      <img
        src="/logo.svg"
        alt="Prominent logo"
        class="logo-img"
        width="32"
        height="36"
      />
      <span class="logo-text">Prominent</span>
    </a>

    <ul class="nav-links">
      {
        links.map((link) => (
          <li>
            <a href={link.href}>{link.label}</a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const navbar = document.getElementById("navbar")!;
  const navbarHeight = navbar.offsetHeight;

  // Initial state based on page position at load
  gsap.set(navbar, { y: window.scrollY <= 10 ? 0 : -navbarHeight });

  ScrollTrigger.create({
    onUpdate: (self) => {
      const scrollY = window.scrollY;

      // Toggle background when scrolled past hero
      navbar.classList.toggle("scrolled", scrollY > 50);

      if (scrollY <= 10) {
        // At the very top — always visible, transparent
        gsap.to(navbar, {
          y: 0,
          duration: 0.35,
          ease: "power2.out",
          overwrite: "auto",
        });
      } else if (self.direction === 1) {
        // Scrolling down — hide off-screen
        gsap.to(navbar, {
          y: -navbarHeight,
          duration: 0.35,
          ease: "power2.out",
          overwrite: "auto",
        });
      } else if (self.direction === -1 && scrollY > 50) {
        // Scrolling up past threshold — show
        gsap.to(navbar, {
          y: 0,
          duration: 0.35,
          ease: "power2.out",
          overwrite: "auto",
        });
      }
    },
  });

  // Smooth-scroll to section when visiting from another page
  const hash = window.location.hash;
  if (hash) {
    setTimeout(() => {
      const target = document.querySelector(hash);
      if (target) {
        target.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    }, 300);
  }

  // Intercept clicks on hash links for smooth scroll
  document.querySelectorAll('.nav-links a[href^="/#"]').forEach((link) => {
    link.addEventListener("click", (e) => {
      const hash = link.getAttribute("href")!.replace("/#", "");
      const target = document.getElementById(hash);
      if (target) {
        e.preventDefault();
        window.scrollTo({ top: target.offsetTop - 96, behavior: "smooth" });
        history.pushState(null, "", `/#${hash}`);
      }
    });
  });
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    padding: 1rem 2rem;
    /* Transparent by default */
    background: transparent;
    pointer-events: auto;
    transition: background 0.3s ease;
  }

  .navbar.scrolled {
    background: rgba(12, 12, 12, 0.95);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .nav-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
  }

  .logo-img {
    width: 42px;
    height: auto;
    filter: brightness(0) invert(1);
  }

  .logo-text {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #fff;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.35);
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.3s ease;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.3);
  }

  .nav-links a:hover {
    color: #ffffff;
  }

  /* Mobile responsiveness */
  @media (max-width: 640px) {
    .navbar {
      padding: 0.75rem 1rem;
    }

    .logo-text {
      font-size: 1.2rem;
    }

    .nav-links {
      gap: 1rem;
    }

    .nav-links a {
      font-size: 0.85rem;
    }
  }
</style>
