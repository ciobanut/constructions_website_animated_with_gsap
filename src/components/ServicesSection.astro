---
interface ServiceItem {
  data: {
    title: string;
    slug: string;
    order: number;
    shortDescription: string;
    icon?: string;
    featured: boolean;
    image: string;
  };
}

interface Props {
  services: ServiceItem[];
}

const { services } = Astro.props;
---

<section id="services-section" class="py-24 md:py-32 bg-black">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Section label -->
    <p
      class="section-label font-['Barlow_Condensed'] text-xs md:text-sm tracking-[0.2em] uppercase text-gray-500 mb-16 md:mb-20"
    >
      Our Expertise
    </p>

    <!-- Services list -->
    <div class="services-list flex flex-col gap-16 md:gap-20">
      {
        services.map((service) => (
          <div
            class="service-item spot-section group cursor-default relative overflow-hidden"
            style="--radius: 100px; --x: 50%; --y: 50%;"
          >
            <!-- Front content layer (visible by default, sits below the overlay) -->
            <div class="relative z-10">
              <!-- Massive title (linked) -->
              <h2 class="service-title">
                <a
                  href={`/services/${service.data.slug}`}
                  class="font-['Barlow_Condensed'] font-bold text-white leading-[0.85] tracking-[-0.02em]
                         text-[clamp(2.8rem,10vw,7rem)] md:text-[clamp(4rem,10vw,7rem)]
                         hover:text-gray-200 transition-colors duration-300"
                >
                  {service.data.title}
                </a>
              </h2>

              <!-- Description — hidden by default, revealed on hover -->
              <div class="service-desc-wrapper overflow-hidden mt-4 md:mt-6">
                <p
                  class="service-desc font-['Barlow'] font-light text-gray-400
                         text-[clamp(0.85rem,1.1vw,1.1rem)] leading-relaxed max-w-2xl
                         translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100
                         transition-all duration-500 ease-out"
                >
                  {service.data.shortDescription}
                </p>
              </div>

              <!-- Decorative separator line -->
              <div
                class="mt-8 md:mt-10 h-px w-0 group-hover:w-full bg-gradient-to-r from-gray-700/60 to-transparent
                       transition-all duration-700 ease-out"
              ></div>
            </div>

            <!-- Spotlight overlay (on top of text, clipped to invisible by default) -->
            {service.data.image && (
              <div
                class="spot-overlay absolute inset-0 z-20 pointer-events-none"
                style={`background-image: url(${service.data.image}); background-size: cover; background-position: center;`}
              >
                <!-- Dark tint for text readability inside the spotlight circle -->
                <div class="absolute inset-0 bg-black/60"></div>
              </div>
            )}
          </div>
        ))
      }
    </div>

  </div>
</section>


<style>

/* ─── Per-item spotlight variables ─── */
.service-item.spot-section {
  --radius: 100px;
  --x: 50%;
  --y: 50%;
}

/* Overlay: invisible by default */
.service-item.spot-section .spot-overlay {
  clip-path: circle(0 at var(--x) var(--y));
  transition: clip-path 0.25s cubic-bezier(0.25, 0.1, 0.25, 1);
}

/* Overlay: revealed on hover */
.service-item.spot-section.hover .spot-overlay {
  clip-path: circle(var(--radius) at var(--x) var(--y));
}

/* Mobile: hide overlay entirely */
@media (max-width: 767px) {
  .service-item.spot-section .spot-overlay {
    clip-path: none !important;
    display: none;
  }
}

/* Reduced motion: never show spotlight */
@media (prefers-reduced-motion: reduce) {
  .service-item.spot-section .spot-overlay {
    clip-path: circle(0) !important;
  }
}

</style>


<script>
  import { gsap } from "gsap";
document.addEventListener("DOMContentLoaded", () => {
  const sections = document.querySelectorAll(".spot-section");

  sections.forEach(section => {
    const setX = gsap.quickSetter(section, "--x", "px");
    const setY = gsap.quickSetter(section, "--y", "px");

    section.addEventListener("mousemove", (e: MouseEvent) => {
      const rect = section.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;

      section.classList.add("hover");

      setX(x);
      setY(y);
    });

    section.addEventListener("mouseleave", () => {
      section.classList.remove("hover");
    });
  });
});
</script>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  (function () {
    var section = document.getElementById("services-section");
    if (!section) return;

    // --- Entrance animation: stagger service titles ---
    var titles = gsap.utils.toArray(".service-title");
    var descs = gsap.utils.toArray(".service-desc");

    // Animate titles
    gsap.fromTo(
      titles,
      { y: 80, opacity: 0, rotateX: -15 },
      {
        y: 0,
        opacity: 1,
        rotateX: 0,
        duration: 1.2,
        stagger: 0.2,
        ease: "power4.out",
        scrollTrigger: {
          trigger: section,
          start: "top 80%",
          toggleActions: "play none none none",
        },
      },
    );

    // Animate descriptions — follow each title with a slight delay
    gsap.fromTo(
      descs,
      { y: 20, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.8,
        stagger: 0.2,
        delay: 0.3,
        ease: "power2.out",
        scrollTrigger: {
          trigger: section,
          start: "top 80%",
          toggleActions: "play none none none",
        },
      },
    );

    // --- Subtle hover effect enhancement on service items ---
    var items = gsap.utils.toArray(".service-item");

    items.forEach(function (item) {
      var title = item.querySelector(".service-title");
      if (!title) return;

      item.addEventListener("mouseenter", function () {
        gsap.to(title, { x: 8, duration: 0.4, ease: "power2.out" });
      });

      item.addEventListener("mouseleave", function () {
        gsap.to(title, { x: 0, duration: 0.5, ease: "power2.out" });
      });
    });
  })();
</script>

<style>
  .service-item:not(:last-child) .service-desc-wrapper {
    /* Ensure only the last separator line is fully visible — handled by the w-0 transition */
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .service-title,
    .service-desc {
      opacity: 1 !important;
      transform: none !important;
    }
    .service-item .h-px {
      width: 100% !important;
    }
    .service-desc {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>
