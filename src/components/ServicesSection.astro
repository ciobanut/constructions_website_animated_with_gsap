---
interface ServiceItem {
  data: {
    title: string;
    slug: string;
    order: number;
    shortDescription: string;
    icon?: string;
    featured: boolean;
    image: string;
  };
}

interface Props {
  services: ServiceItem[];
}

const { services } = Astro.props;
---

<section id="services-section" class="py-24 md:py-32 bg-black relative overflow-hidden">
  <!-- Background image layers for crossfade on hover -->
  <div id="services-bg-container" class="absolute inset-0 -z-0 overflow-hidden" aria-hidden="true">
    <!-- Active layer — shows the current image -->
    <div id="bg-active" class="bg-layer absolute inset-0 bg-cover bg-center" style="opacity: 0;">
      <div class="absolute inset-0 bg-black/70"></div>
    </div>
    <!-- Incoming layer — fades in on hover -->
    <div id="bg-incoming" class="bg-layer absolute inset-0 bg-cover bg-center" style="opacity: 0;">
      <div class="absolute inset-0 bg-black/70"></div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <!-- Section label -->
    <p
      class="section-label font-['Barlow_Condensed'] text-xs md:text-sm tracking-[0.2em] uppercase text-gray-500 mb-16 md:mb-20"
    >
      Our Expertise
    </p>

    <!-- Services list — no gap, padding on each item to avoid dead hover zones -->
    <div class="services-list flex flex-col">
      {
        services.map((service) => (
          <div
            class="service-item group cursor-default relative overflow-hidden"
            data-bg-image={service.data.image || ''}
          >
            <!-- Front content layer -->
            <div class="relative z-10">
              <!-- Massive title (linked) -->
              <h2 class="service-title">
                <a
                  href={`/services/${service.data.slug}`}
                  class="font-['Barlow_Condensed'] font-bold text-white leading-[0.85] tracking-[-0.02em]
                         text-[clamp(2.8rem,10vw,7rem)] md:text-[clamp(4rem,10vw,7rem)]
                         hover:text-gray-200 transition-colors duration-300"
                >
                  {service.data.title}
                </a>
              </h2>

              <!-- Description — hidden by default, revealed on hover -->
              <div class="service-desc-wrapper overflow-hidden mt-4 md:mt-6">
                <p
                  class="service-desc font-['Barlow'] font-light text-gray-400
                         text-[clamp(0.85rem,1.1vw,1.1rem)] leading-relaxed max-w-2xl
                         translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100
                         transition-all duration-500 ease-out"
                >
                  {service.data.shortDescription}
                </p>
              </div>

              <!-- Decorative separator line -->
              <div
                class="mt-8 md:mt-10 h-px w-0 group-hover:w-full bg-gradient-to-r from-gray-700/60 to-transparent
                       transition-all duration-700 ease-out"
              ></div>
            </div>
          </div>
        ))
      }
    </div>

  </div>
</section>


<style>
  /* Background layers sit behind content, will-change for compositor optimization */
  .bg-layer {
    will-change: opacity;
  }
</style>


<script>
  import { gsap } from "gsap";

  document.addEventListener("DOMContentLoaded", () => {
    const section = document.getElementById("services-section");
    const bgActive = document.getElementById("bg-active");
    const bgIncoming = document.getElementById("bg-incoming");
    const items = document.querySelectorAll<HTMLElement>(".service-item");

    if (!section || !bgActive || !bgIncoming || !items.length) return;

    let currentImage: string | null = null;
    let isTransitioning = false;
    let activeTween: gsap.core.Timeline | null = null;

    // --- Preload all service background images so they are ready on hover ---
    const preloadImages = new Set<string>();
    items.forEach((item) => {
      const bg = item.getAttribute("data-bg-image");
      if (bg) preloadImages.add(bg);
    });
    preloadImages.forEach((src) => {
      const img = new Image();
      img.src = src;
    });

    // Check reduced motion preference
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    const fadeDuration = prefersReducedMotion ? 0 : 0.6;

    /**
     * Crossfade to a new background image, or fade to black if url is null.
     */
    const crossfadeTo = (newImage: string | null) => {
      // Skip if already showing this image
      if (newImage === currentImage) return;

      // Kill any in-progress crossfade
      if (activeTween) {
        activeTween.kill();
        activeTween = null;
      }

      isTransitioning = true;

      if (!newImage) {
        // --- Fade to black ---
        // Both layers fade out, revealing the section's bg-black
        activeTween = gsap.timeline({
          onComplete: () => {
            gsap.set([bgActive, bgIncoming], { opacity: 0 });
            currentImage = null;
            isTransitioning = false;
            activeTween = null;
          },
        });
        activeTween.to(bgActive, { opacity: 0, duration: fadeDuration, ease: "power2.out" }, 0)
                     .to(bgIncoming, { opacity: 0, duration: fadeDuration, ease: "power2.out" }, 0);
        return;
      }

      if (currentImage === null) {
        // --- From black to first image: just fade active in ---
        bgActive.style.backgroundImage = `url(${newImage})`;
        gsap.set(bgActive, { opacity: 0 });
        gsap.set(bgIncoming, { opacity: 0 });

        activeTween = gsap.to(bgActive, {
          opacity: 1,
          duration: fadeDuration,
          ease: "power2.out",
          onComplete: () => {
            currentImage = newImage;
            isTransitioning = false;
            activeTween = null;
          },
        });
        return;
      }

      // --- Crossfade between two images ---
      // Set incoming layer to new image
      bgIncoming.style.backgroundImage = `url(${newImage})`;
      gsap.set(bgIncoming, { opacity: 0 });
      gsap.set(bgActive, { opacity: 1 });

      activeTween = gsap.timeline({
        onComplete: () => {
          // Swap: incoming → active
          bgActive.style.backgroundImage = `url(${newImage})`;
          gsap.set(bgActive, { opacity: 1 });
          gsap.set(bgIncoming, { opacity: 0 });
          currentImage = newImage;
          isTransitioning = false;
          activeTween = null;
        },
      });
      activeTween.to(bgActive, { opacity: 0, duration: fadeDuration, ease: "power2.out" }, 0)
                   .to(bgIncoming, { opacity: 1, duration: fadeDuration, ease: "power2.out" }, 0);
    };

    // Attach hover events
    items.forEach((item) => {
      const bgImage = item.getAttribute("data-bg-image");
      if (!bgImage) return;

      item.addEventListener("mouseenter", () => crossfadeTo(bgImage));
    });

    // When mouse leaves the entire section, fade to black
    section.addEventListener("mouseleave", () => crossfadeTo(null));
  });
</script>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  (function () {
    var section = document.getElementById("services-section");
    if (!section) return;

    // --- Entrance animation: stagger service titles ---
    var titles = gsap.utils.toArray(".service-title");
    var descs = gsap.utils.toArray(".service-desc");

    // Animate titles
    gsap.fromTo(
      titles,
      { y: 80, opacity: 0, rotateX: -15 },
      {
        y: 0,
        opacity: 1,
        rotateX: 0,
        duration: 1.2,
        stagger: 0.2,
        ease: "power4.out",
        scrollTrigger: {
          trigger: section,
          start: "top 80%",
          toggleActions: "play none none none",
        },
      },
    );

    // Animate descriptions — follow each title with a slight delay
    gsap.fromTo(
      descs,
      { y: 20, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.8,
        stagger: 0.2,
        delay: 0.3,
        ease: "power2.out",
        scrollTrigger: {
          trigger: section,
          start: "top 80%",
          toggleActions: "play none none none",
        },
      },
    );

    // --- Subtle hover effect enhancement on service items ---
    var items = gsap.utils.toArray(".service-item");

    items.forEach(function (item) {
      var title = item.querySelector(".service-title");
      if (!title) return;

      item.addEventListener("mouseenter", function () {
        gsap.to(title, { x: 8, duration: 0.4, ease: "power2.out" });
      });

      item.addEventListener("mouseleave", function () {
        gsap.to(title, { x: 0, duration: 0.5, ease: "power2.out" });
      });
    });
  })();
</script>

<style>
  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .service-title,
    .service-desc {
      opacity: 1 !important;
      transform: none !important;
    }
    .service-item .h-px {
      width: 100% !important;
    }
    .service-desc {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>
