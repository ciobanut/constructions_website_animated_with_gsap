---
export interface Props {
  images: string[];
  title: string;
}

const { images, title } = Astro.props;
---

{
  images.length > 0 && (
    <section class="py-16">
      <h2 class="text-2xl font-['Barlow_Condensed'] font-bold uppercase tracking-wide text-gray-200 mb-8">
        Project Gallery
      </h2>
      <div id="project-gallery" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {
          images.map((img, i) => (
            <a
              href={img}
              data-fancybox="project-gallery"
              data-caption={`${title} - Image ${i + 1}`}
              class="gallery-item group relative aspect-[4/3] overflow-hidden rounded-xl bg-[#1a1a1a] block"
            >
              <img
                src={img}
                alt={`${title} - Image ${i + 1}`}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                loading={i < 4 ? 'eager' : 'lazy'}
              />
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-300" />
            </a>
          ))
        }
      </div>
    </section>
  )
}

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  import { Fancybox } from '@fancyapps/ui/dist/fancybox/';
  import '@fancyapps/ui/dist/fancybox/fancybox.css';

  gsap.registerPlugin(ScrollTrigger);

  // --- GSAP entrance animations ---
  const items = document.querySelectorAll<HTMLElement>('.gallery-item');
  items.forEach((item, i) => {
    gsap.from(item, {
      y: 40,
      opacity: 0,
      duration: 0.6,
      delay: i * 0.05,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: item,
        start: 'top 90%',
        toggleActions: 'play none none none',
      },
    });
  });

  // --- Fancybox ---
  Fancybox.bind('[data-fancybox="project-gallery"]', {
    Carousel: {
      // Infinite loop (was `loop: true` in lightGallery)
      infinite: true,

      // Thumbnail strip
      Thumbs: {
        type: 'classic',
      },

      // Custom toolbar layout: counter | zoom controls | autoplay, thumbs, fullscreen, close
      Toolbar: {
        display: {
          left: ['counter'],
          middle: ['zoomIn', 'zoomOut', 'toggle1to1'],
          right: ['autoplay', 'thumbs', 'toggleFull', 'close'],
        },
      },

      // Caption format: "2 of 5 — Image title"
      formatCaption: (carousel, slide) => {
        const total = carousel.getSlides().length;
        return `${slide.index + 1} of ${total}<br />${slide.caption || ''}`;
      },
    },

    // Drag up/down to close
    dragToClose: true,

    // Zoom animation from thumbnail to full image
    zoomEffect: true,

    // Scroll wheel navigates slides
    wheel: 'slide',
  });
</script>
