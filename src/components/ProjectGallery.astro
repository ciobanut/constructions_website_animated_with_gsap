---
export interface Props {
  images: string[];
  title: string;
}

const { images, title } = Astro.props;
---

{
  images.length > 0 && (
    <section class="py-16">
      <h2 class="text-2xl font-['Barlow_Condensed'] font-bold uppercase tracking-wide text-gray-200 mb-8">
        Project Gallery
      </h2>
      <div id="project-gallery" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {
          images.map((img, i) => (
            <a
              href={img}
              data-lg-size="1920-1080"
              class="gallery-item group relative aspect-[4/3] overflow-hidden rounded-xl bg-[#1a1a1a] block"
            >
              <img
                src={img}
                alt={`${title} - Image ${i + 1}`}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                loading={i < 4 ? 'eager' : 'lazy'}
              />
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-300" />
            </a>
          ))
        }
      </div>
    </section>
  )
}

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  import lightGallery from 'lightgallery';
  import 'lightgallery/css/lightgallery.css';
  import 'lightgallery/css/lg-zoom.css';
  import 'lightgallery/css/lg-fullscreen.css';
  import 'lightgallery/css/lg-thumbnail.css';
  import 'lightgallery/css/lg-autoplay.css';
  import 'lightgallery/css/lg-medium-zoom.css';

  import lgZoom from 'lightgallery/plugins/zoom';
  import lgAutoplay from 'lightgallery/plugins/autoplay';
  import lgFullscreen from 'lightgallery/plugins/fullscreen';
  import lgHash from 'lightgallery/plugins/hash';
  import lgThumbnail from 'lightgallery/plugins/thumbnail';
  import lgMediumZoom from 'lightgallery/plugins/mediumzoom';

  gsap.registerPlugin(ScrollTrigger);

  // --- GSAP entrance animations ---
  const items = document.querySelectorAll<HTMLElement>('.gallery-item');
  items.forEach((item, i) => {
    gsap.from(item, {
      y: 40,
      opacity: 0,
      duration: 0.6,
      delay: i * 0.05,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: item,
        start: 'top 90%',
        toggleActions: 'play none none none',
      },
    });
  });

  // --- lightGallery ---
  const galleryElement = document.getElementById('project-gallery');

  if (galleryElement) {
    const lg = lightGallery(galleryElement, {
      plugins: [lgZoom, lgAutoplay, lgFullscreen, lgHash, lgThumbnail],

      // License key (free for open-source / non-commercial use)
      licenseKey: '0000-0000-000-0000',

      speed: 500,
      loop: true,
      download: false,
      counter: true,
      controls: true,
      mousewheel: true,
      preload: 2,
      enableDrag: true,
      enableSwipe: true,
      swipeThreshold: 50,

      // Thumbnail strip
      thumbnail: true,
      animateThumb: true,

      // Zoom
      zoom: true,
      actualSize: true,

      // Autoplay / slideshow
      autoplay: true,
      autoplayControls: true,
      progressBar: true,

      // Fullscreen
      fullScreen: true,

      // Medium zoom (pinch-to-zoom on mobile)
      mediumZoom: true,

      // Hash in URL
      hash: true,
    });

    // Cleanup on page leave — prevents memory leaks
    window.addEventListener('beforeunload', () => {
      if (lg) lg.destroy();
    });
  }
</script>
