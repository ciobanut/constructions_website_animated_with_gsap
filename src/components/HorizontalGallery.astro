---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
const projectCount = projects.length;
---

<section id="projects" class="projects-section">
  <div class="projects-container">
    <!-- Track orizontal — intro slide + un slide per proiect -->
    <div class="projects-track">
      <!-- Intro Slide — fără background, cu header și animații -->
      <div class="project-slide intro-slide">
        <div class="intro-content">
          <span class="intro-label">Our Work</span>
          <h2 class="intro-title">Featured Projects</h2>
          <p class="intro-desc">
            Delivering quality construction and design solutions across Iraq and beyond
          </p>
          <button class="view-all-btn" data-view-all>View All Projects</button>
        </div>
      </div>

      <!-- Proiecte -->
      {projects.map((project) => (
        <a href={`/proiecte/${project.data.slug}`} class="project-slide">
          <img
            src={project.data.coverImage}
            alt={project.data.title}
            loading="lazy"
          />
          <div class="project-slide-overlay">
            <h3 class="slide-title">{project.data.title}</h3>
            <p class="slide-meta">
              {project.data.location} &middot; {project.data.constructionArea}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const track = document.querySelector<HTMLElement>('.projects-track');
  const container = document.querySelector<HTMLElement>('.projects-container');
  const introContent = document.querySelector<HTMLElement>('.intro-content');
  const viewAllBtn = document.querySelector<HTMLButtonElement>('[data-view-all]');

  if (track && container) {
    const getScrollDistance = () => track.scrollWidth - window.innerWidth;

    // Animația principală — track-ul se mișcă orizontal
    gsap.to(track, {
      xPercent: () => {
        const d = getScrollDistance();
        return -(d / track.scrollWidth) * 100;
      },
      ease: 'none',
      scrollTrigger: {
        id: 'gallery-horizontal',
        trigger: container,
        pin: true,
        start: 'top top',
        end: () => `+=${getScrollDistance()}`,
        scrub: 1,
        invalidateOnRefresh: true,
      },
    });

    // Animații de intrare pentru intro slide
    if (introContent) {
      const introChildren = introContent.children;
      gsap.from(introChildren, {
        y: 60,
        opacity: 0,
        duration: 1,
        stagger: 0.15,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: container,
          start: 'top 90%',
          toggleActions: 'play none none none',
        },
      });
    }

    // Click pe "View All Projects" → scroll la primul proiect
    if (viewAllBtn) {
      viewAllBtn.addEventListener('click', () => {
        const st = ScrollTrigger.getById('gallery-horizontal');
        if (st) {
          const targetY = st.start + window.innerWidth;
          window.scrollTo({ top: targetY, behavior: 'smooth' });
        }
      });
    }
  }
</script>

<style>
  .projects-container {
    position: relative;
    width: 100vw;
    height: 100dvh;
    overflow: hidden;
    background: #0c0c0c;
  }

  .projects-track {
    display: flex;
    height: 100%;
    width: max-content;
    will-change: transform;
  }

  /* ───────── Intro Slide ───────── */
  .intro-slide {
    display: flex !important;
    align-items: center;
    justify-content: center;
    background: #0c0c0c;
  }

  .intro-content {
    text-align: center;
    max-width: 42rem;
    padding: 2rem;
    justify-self: center;
  }

  .intro-label {
    display: block;
    color: #9ca3af;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .intro-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #f3f4f6;
    margin: 0;
    line-height: 1.1;
  }

  .intro-desc {
    color: #9ca3af;
    margin-top: 1rem;
    font-size: clamp(0.95rem, 1.5vw, 1.15rem);
    line-height: 1.6;
  }

  .view-all-btn {
    display: inline-block;
    margin-top: 2rem;
    padding: 1.25rem 4.5rem;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #f3f4f6;
    border: 1px solid #f3f4f6;
    cursor: pointer;
    transition: transform 0.3s ease, background 0.3s ease;
  }

  .view-all-btn:hover {
    transform: scale(1.05);
    background: #ffffff;
    color: #0c0c0c;
  }

  .view-all-btn:active {
    transform: scale(0.97);
  }

  /* ───────── Project Slides ───────── */
  .project-slide {
    position: relative;
    width: 100vw;
    height: 100%;
    flex-shrink: 0;
    display: block;
    overflow: hidden;
  }

  .project-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Overlay — VIZIBIL PERMANENT, bottom-left */
  .project-slide-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.75) 0%,
      rgba(0, 0, 0, 0.15) 40%,
      transparent 60%
    );
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    padding: 4rem;
    color: white;
  }

  .slide-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 700;
    text-transform: uppercase;
    color: #f3f4f6;
    margin: 0;
  }

  .slide-meta {
    font-size: 0.95rem;
    color: #d1d5db;
    margin: 0.5rem 0 0;
  }

  @media (max-width: 768px) {
    .project-slide-overlay {
      padding: 2rem;
    }
    .slide-title {
      font-size: 1.5rem;
    }
    .view-all-btn {
      padding: 0.75rem 2rem;
      font-size: 1rem;
    }
  }
</style>
