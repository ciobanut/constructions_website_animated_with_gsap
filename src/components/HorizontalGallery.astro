---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

<section id="projects" class="projects-section">
  <div class="projects-container">
    <!-- Header — dispare treptat la scroll -->
    <div class="projects-header">
      <span class="section-label">Our Work</span>
      <h2 class="section-title">Featured Projects</h2>
      <p class="section-desc">
        Delivering quality construction and design solutions across Iraq and beyond
      </p>
    </div>

    <!-- Track orizontal — un slide per proiect -->
    <div class="projects-track">
      {projects.map((project) => (
        <a href={`/proiecte/${project.data.slug}`} class="project-slide">
          <img
            src={project.data.coverImage}
            alt={project.data.title}
            loading="lazy"
          />
          <div class="project-slide-overlay">
            <h3 class="slide-title">{project.data.title}</h3>
            <p class="slide-meta">
              {project.data.location} &middot; {project.data.constructionArea}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const track = document.querySelector<HTMLElement>('.projects-track');
  const container = document.querySelector<HTMLElement>('.projects-container');
  const header = document.querySelector<HTMLElement>('.projects-header');

  if (track && container) {
    const getScrollDistance = () => track.scrollWidth - window.innerWidth;

    // Animația principală — track-ul se mișcă orizontal
    gsap.to(track, {
      xPercent: () => {
        const d = getScrollDistance();
        return -(d / track.scrollWidth) * 100;
      },
      ease: 'none',
      scrollTrigger: {
        trigger: container,
        pin: true,
        start: 'top top',
        end: () => `+=${getScrollDistance()}`,
        scrub: 1,
        invalidateOnRefresh: true,
      },
    });

    // Fade-out pentru header
    if (header) {
      gsap.to(header, {
        opacity: 0,
        scale: 0.95,
        scrollTrigger: {
          trigger: container,
          start: 'top top',
          end: '+=300',
          scrub: 1,
        },
      });
    }
  }
</script>

<style>
  .projects-section {
    /* ocupă tot viewport-ul când e pinned */
  }

  .projects-container {
    position: relative;
    width: 100vw;
    height: 100dvh;
    overflow: hidden;
    background: #0c0c0c;
  }

  .projects-header {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    pointer-events: none;
    padding: 2rem;
  }

  .section-label {
    color: #9ca3af;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .section-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #f3f4f6;
    margin-top: 0.75rem;
  }

  .section-desc {
    color: #9ca3af;
    margin-top: 1rem;
    max-width: 32rem;
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
  }

  .projects-track {
    display: flex;
    height: 100%;
    width: max-content;
    will-change: transform;
  }

  .project-slide {
    position: relative;
    width: 100vw;
    height: 100%;
    flex-shrink: 0;
    display: block;
    overflow: hidden;
  }

  .project-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Overlay — VIZIBIL PERMANENT, bottom-left */
  .project-slide-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.75) 0%,
      rgba(0, 0, 0, 0.15) 40%,
      transparent 60%
    );
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    padding: 4rem;
    color: white;
  }

  .slide-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 700;
    text-transform: uppercase;
    color: #f3f4f6;
    margin: 0;
  }

  .slide-meta {
    font-size: 0.95rem;
    color: #d1d5db;
    margin: 0.5rem 0 0;
  }

  @media (max-width: 768px) {
    .project-slide-overlay {
      padding: 2rem;
    }
    .slide-title {
      font-size: 1.5rem;
    }
  }
</style>
