---
import type { CollectionEntry } from "astro:content";
import HeroCover from "./HeroCover.astro";
import Button from "./ui/Button.astro";

export interface Props {
  projects: CollectionEntry<"projects">[];
}

const { projects } = Astro.props;
---

<!--
  Horizontal track (flex row) with per-slide ScrollTriggers via containerAnimation.
  Each slide, as it exits to the left, scales from 1→0.7 and fades out
  with the same 0.9/0.1 timing split as the GreenSock example.
-->
<section id="projects" class="projects-section">
  <div class="projects-container">
    <!-- Fixed intro/title — stays in place while project slides scroll over it -->
    <div class="intro-fixed">
      <div class="intro-content">
        <span class="intro-label">Our Work</span>
        <h2 class="intro-title">Featured Projects</h2>
        <p class="intro-desc">
          Delivering quality construction and design solutions across Iraq and
          beyond
        </p>
        <Button variant="outline" size="lg" data-view-all class="mt-8">View All Projects</Button>
      </div>
    </div>

    <!-- Horizontal track — only project slides, no intro -->
    <div class="projects-track">
      {
        projects.map((project) => (
          <a href={`/projects/${project.data.slug}`} class="project-slide">
            <HeroCover
              coverImage={project.data.coverImage}
              title={project.data.title}
              category={project.data.category}
              location={project.data.location}
              constructionArea={project.data.constructionArea}
              year={project.data.year}
              status={project.data.status}
            />
          </a>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  (function initGallery() {
    const container = document.querySelector<HTMLElement>(
      ".projects-container",
    );
    const track = document.querySelector<HTMLElement>(".projects-track");
    const introFixed = document.querySelector<HTMLElement>(".intro-fixed");
    const slides = gsap.utils.toArray<HTMLElement>(".project-slide");
    const introContent = document.querySelector<HTMLElement>(".intro-content");
    const viewAllBtn =
      document.querySelector<HTMLButtonElement>("[data-view-all]");

    if (!track || !container || slides.length === 0 || !introFixed) return;

    // ── 1. Horizontal track tween ──────────────────────────────────
    // Track starts offset by 1 viewport so the first project slide
    // enters from the right, leaving the fixed intro visible.
    const scrollTween = gsap.fromTo(
      track,
      { x: () => window.innerWidth },
      {
        x: () => -(track.scrollWidth - window.innerWidth),
        ease: "none",
        onUpdate: function () {
          // Fade out the intro as the last slides cover it
          const p = this.progress();
          const fadeStart = 0.6;
          const opacity =
            p > fadeStart
              ? 1 - (p - fadeStart) / (1 - fadeStart)
              : 1;
          introFixed.style.opacity = String(opacity);
        },
        scrollTrigger: {
          id: "gallery-horizontal",
          trigger: container,
          pin: true,
          start: "top top",
          end: () => `+=${track.scrollWidth}`,
          scrub: true,
          invalidateOnRefresh: true,
        },
      },
    );

    // ── 2. Per-slide exit animation ────────────────────────────────
    // Each project slide scales down & fades as it scrolls out left
    slides.slice(0, -1).forEach((slide) => {
      const tl = gsap.timeline({
        scrollTrigger: {
          containerAnimation: scrollTween,
          trigger: slide,
          start: "left left",
          end: "right left",
          scrub: true,
        },
      });

      // 0.9 of the animation → scale 1→0.7, x 0→100vw, opacity 1→0.5
      // 0.1 of the animation → opacity 0.5→0
      tl.fromTo(
        slide,
        { scale: 1, x: 0, opacity: 1 },
        {
          scale: 0.7,
          x: "100vw",
          duration: 0.9,
          ease: "power2.in",
          borderRadius: "30px",
          filter: "blur(1px)",
        },
      ).to(slide, { opacity: 0, duration: 0.1, ease: "power2.in" });
    });

    // ── 3. Intro content entrance animation ────────────────────────
    if (introContent) {
      const introChildren = gsap.utils.toArray(introContent.children);
      gsap.fromTo(
        introChildren,
        { y: 60, autoAlpha: 0 },
        {
          y: 0,
          autoAlpha: 1,
          duration: 1,
          stagger: 0.15,
          ease: "power3.out",
          scrollTrigger: {
            trigger: container,
            start: "top 90%",
            toggleActions: "play none none none",
          },
        },
      );
    }

    // ── 4. View All → scroll to first project slide ────────────────
    if (viewAllBtn) {
      viewAllBtn.addEventListener("click", () => {
        const st = ScrollTrigger.getById("gallery-horizontal");
        if (st) {
          // +1 viewport because the first project slide is
          // offset right at the start of the pin
          const targetY = st.start + window.innerWidth;
          window.scrollTo({ top: targetY, behavior: "smooth" });
        }
      });
    }

    // ── 5. Click project slide → centre + navigate ─────────────────
    let isAnimating = false;

    container.addEventListener("click", (e) => {
      if (isAnimating) return;

      const anchor = (e.target as HTMLElement).closest<HTMLAnchorElement>(
        "a.project-slide",
      );
      if (!anchor) return;

      const href = anchor.getAttribute("href");
      if (!href) return;

      e.preventDefault();

      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        window.location.href = href;
        return;
      }

      const st = ScrollTrigger.getById("gallery-horizontal");
      if (!st) {
        window.location.href = href;
        return;
      }

      const slideIndex = slides.indexOf(anchor);
      if (slideIndex < 0) {
        window.location.href = href;
        return;
      }

      // +1 viewport offset because the track starts shifted right
      const targetY = st.start + (slideIndex + 1) * window.innerWidth;

      if (Math.abs(window.scrollY - targetY) < 1) {
        window.location.href = href;
        return;
      }

      isAnimating = true;

      const navigate = () => {
        window.location.href = href;
      };

      window.scrollTo({ top: targetY, behavior: "smooth" });

      let cleanedUp = false;
      const done = () => {
        if (cleanedUp) return;
        cleanedUp = true;
        window.removeEventListener("scrollend", done);
        cancelAnimationFrame(pollId);
        isAnimating = false;
        navigate();
      };

      window.addEventListener("scrollend", done);

      const pollId = requestAnimationFrame(function check() {
        if (Math.abs(window.scrollY - targetY) < 2) {
          done();
          return;
        }
        requestAnimationFrame(check);
      });

      setTimeout(done, 1000);
    });
  })();
</script>

<style>
  .projects-container {
    position: relative;
    width: 100vw;
    height: 100dvh;
    overflow: hidden;
    background: #0c0c0c;
  }

  .projects-track {
    position: relative;
    z-index: 2;
    display: flex;
    height: 100%;
    width: max-content;
    will-change: transform;
  }

  /* ───────── Fixed Intro (behind project slides) ───────── */
  .intro-fixed {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0c0c0c;
  }

  .intro-content {
    text-align: center;
    max-width: 40rem;
    padding: 2rem;
  }

  .intro-label {
    display: block;
    color: #9ca3af;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .intro-title {
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #f3f4f6;
    margin: 0;
    line-height: 1.1;
  }

  .intro-desc {
    color: #9ca3af;
    margin-top: 1rem;
    font-size: clamp(0.95rem, 1.5vw, 1.15rem);
    line-height: 1.6;
    text-wrap: balance;
  }


  /* ───────── Project Slides ───────── */
  .project-slide {
    position: relative;
    width: 100vw;
    height: 100%;
    flex-shrink: 0;
    display: block;
    overflow: hidden;
    will-change: transform, opacity;
  }

  .project-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

</style>
