---
import type { CollectionEntry } from "astro:content";
import HeroCover from "./HeroCover.astro";

export interface Props {
  projects: CollectionEntry<"projects">[];
}

const { projects } = Astro.props;
---

<!--
  Horizontal track (flex row) with per-slide ScrollTriggers via containerAnimation.
  Each slide, as it exits to the left, scales from 1→0.7 and fades out
  with the same 0.9/0.1 timing split as the GreenSock example.
-->
<section id="projects" class="projects-section">
  <div class="projects-container">
    <div class="projects-track">
      <!-- Intro Slide -->
      <div class="project-slide intro-slide">
        <div class="intro-content">
          <span class="intro-label">Our Work</span>
          <h2 class="intro-title">Featured Projects</h2>
          <p class="intro-desc">
            Delivering quality construction and design solutions across Iraq and
            beyond
          </p>
          <button class="view-all-btn" data-view-all>View All Projects</button>
        </div>
      </div>

      <!-- Projects — full HeroCover style -->
      {
        projects.map((project) => (
          <a href={`/projects/${project.data.slug}`} class="project-slide">
            <HeroCover
              coverImage={project.data.coverImage}
              title={project.data.title}
              category={project.data.category}
              location={project.data.location}
              constructionArea={project.data.constructionArea}
              year={project.data.year}
              status={project.data.status}
            />
          </a>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  (function initGallery() {
    const container = document.querySelector<HTMLElement>(
      ".projects-container",
    );
    const track = document.querySelector<HTMLElement>(".projects-track");
    const slides = gsap.utils.toArray<HTMLElement>(".project-slide");
    const introContent = document.querySelector<HTMLElement>(".intro-content");
    const viewAllBtn =
      document.querySelector<HTMLButtonElement>("[data-view-all]");

    if (!track || !container || slides.length === 0) return;

    const getScrollDistance = () => track.scrollWidth - window.innerWidth;

    // 1. Horizontal track tween → drives containerAnimation
    const scrollTween = gsap.to(track, {
      xPercent: () => {
        const d = getScrollDistance();
        return -(d / track.scrollWidth) * 100;
      },
      ease: "none",
      scrollTrigger: {
        id: "gallery-horizontal",
        trigger: container,
        pin: true,
        start: "top top",
        end: () => `+=${getScrollDistance()}`,
        scrub: true,
        invalidateOnRefresh: true,
      },
    });

    // 2. Per-slide exit animation (mirrors the GreenSock example)
    // Each slide animates from fully visible to scaled+faded as it scrolls out left
    slides.slice(0, -1).forEach((slide) => {
      const tl = gsap.timeline({
        scrollTrigger: {
          containerAnimation: scrollTween,
          trigger: slide,
          start: "left left", // slide is fully in viewport
          end: "right left", // slide has fully exited to the left
          scrub: true,
        },
      });

      // Exact structure from the example:
      // 0.9 of the animation → scale 1→0.7, x 0→100vw (opposite direction), opacity 1→0.5
      // 0.1 of the animation → opacity 0.5→0
      tl.fromTo(
        slide,
        { scale: 1, x: 0, opacity: 1 },
        {
          scale: 0.7,
          x: "100vw",
          opacity: 0.5,
          duration: 0.9,
          ease: "power2.in",
          borderRadius: "30px",
          filter: "blur(1px)",
        },
      ).to(slide, { opacity: 0, duration: 0.1, ease: "power2.in" });
    });

    // 3. Intro slide entrance animation
    if (introContent) {
      const introChildren = introContent.children;
      gsap.from(introChildren, {
        y: 60,
        opacity: 0,
        duration: 1,
        stagger: 0.15,
        ease: "power3.out",
        scrollTrigger: {
          trigger: container,
          start: "top 90%",
          toggleActions: "play none none none",
        },
      });
    }

    // 4. Click "View All Projects" → scroll to first project slide
    if (viewAllBtn) {
      viewAllBtn.addEventListener("click", () => {
        const st = ScrollTrigger.getById("gallery-horizontal");
        if (st) {
          const targetY = st.start + window.innerWidth;
          window.scrollTo({ top: targetY, behavior: "smooth" });
        }
      });
    }

    // 5. Click project slide → center it in viewport quickly, then navigate
    //    Prevents the jarring visual jump when an off-center slide is clicked
    let isAnimating = false;

    container.addEventListener("click", (e) => {
      if (isAnimating) return;

      const anchor = (e.target as HTMLElement).closest<HTMLAnchorElement>(
        "a.project-slide",
      );
      if (!anchor) return;

      const href = anchor.getAttribute("href");
      if (!href) return;

      e.preventDefault();

      // prefers-reduced-motion → navigate immediately
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        window.location.href = href;
        return;
      }

      const st = ScrollTrigger.getById("gallery-horizontal");
      if (!st) {
        window.location.href = href;
        return;
      }

      const slideIndex = slides.indexOf(anchor);
      if (slideIndex < 0) {
        window.location.href = href;
        return;
      }

      // Slide already centered → navigate directly
      const targetY = st.start + slideIndex * window.innerWidth;
      if (Math.abs(window.scrollY - targetY) < 1) {
        window.location.href = href;
        return;
      }

      isAnimating = true;

      const navigate = () => {
        window.location.href = href;
      };

      // Use native scrollTo (same mechanism as "View All" button) to
      // avoid conflicts with ScrollTrigger pin/scrub.
      window.scrollTo({ top: targetY, behavior: "smooth" });

      // Detect scroll completion: scrollend event + polling + timeout
      let cleanedUp = false;
      const done = () => {
        if (cleanedUp) return;
        cleanedUp = true;
        window.removeEventListener("scrollend", done);
        cancelAnimationFrame(pollId);
        isAnimating = false;
        navigate();
      };

      window.addEventListener("scrollend", done);

      // RAF polling: once we reach the target → navigate
      const pollId = requestAnimationFrame(function check() {
        if (Math.abs(window.scrollY - targetY) < 2) {
          done();
          return;
        }
        requestAnimationFrame(check);
      });

      // Safety timeout: 1s (smooth scroll usually takes 300-500ms)
      setTimeout(done, 1000);
    });
  })();
</script>

<style>
  .projects-container {
    position: relative;
    width: 100vw;
    height: 100dvh;
    overflow: hidden;
    background: #0c0c0c;
  }

  .projects-track {
    display: flex;
    height: 100%;
    width: max-content;
    will-change: transform;
  }

  /* ───────── Intro Slide ───────── */
  .intro-slide {
    display: flex !important;
    align-items: center;
    justify-content: center;
    background: #0c0c0c;
  }

  .intro-content {
    text-align: center;
    max-width: 40rem;
    padding: 2rem;
    justify-self: center;
  }

  .intro-label {
    display: block;
    color: #9ca3af;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .intro-title {
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #f3f4f6;
    margin: 0;
    line-height: 1.1;
  }

  .intro-desc {
    color: #9ca3af;
    margin-top: 1rem;
    font-size: clamp(0.95rem, 1.5vw, 1.15rem);
    line-height: 1.6;
    text-wrap: balance;
  }

  .view-all-btn {
    display: inline-block;
    margin-top: 2rem;
    padding: 1.25rem 4.5rem;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #f3f4f6;
    border: 1px solid #f3f4f6;
    cursor: pointer;
    transition:
      transform 0.3s ease,
      background 0.3s ease;
  }

  .view-all-btn:hover {
    transform: scale(1.05);
    background: #ffffff;
    color: #0c0c0c;
  }

  .view-all-btn:active {
    transform: scale(0.97);
  }

  /* ───────── Project Slides ───────── */
  .project-slide {
    position: relative;
    width: 100vw;
    height: 100%;
    flex-shrink: 0;
    display: block;
    overflow: hidden;
    will-change: transform, opacity;
  }

  .project-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .view-all-btn {
      padding: 0.75rem 2rem;
      font-size: 1rem;
    }
  }
</style>
