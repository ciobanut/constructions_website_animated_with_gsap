<!--
  CustomCursor — animated mouse stalker.
  A circle that follows the mouse with lerp easing, fades in/out on window
  enter/leave, and shows "open" text when hovering links.
-->
<div id="mouse-stalker" class="mouse-stalker">
  <div class="mouse-stalker__container">
    <div class="mouse-stalker--circle">
      <span class="mouse-stalker--text">open</span>
    </div>
  </div>
</div>

<script>
  (function initMouseStalker() {
    const stalker = document.getElementById("mouse-stalker");
    if (!stalker) return;

    // ── Only on devices with a fine pointer (no touch) ──
    if (!window.matchMedia("(pointer: fine)").matches) {
      stalker.style.display = "none";
      return;
    }

    // ── State ──
    const pos = {
      stalker: {
        x: window.innerWidth / 2,
        y: window.innerHeight / 2,
      },
      mouse: {
        x: window.innerWidth / 2,
        y: window.innerHeight / 2,
      },
    };

    let running = false;

    // ── Toggle visibility ──
    function show() {
      stalker.classList.add("show");
      if (!running) {
        running = true;
        requestAnimationFrame(tick);
      }
    }

    function hide() {
      stalker.classList.remove("show");
    }

    document.body.addEventListener("mouseenter", show);
    document.body.addEventListener("mouseleave", hide);

    // ── Mouse tracking ──
    function onMouseMove(e: MouseEvent) {
      pos.mouse.x = e.clientX;
      pos.mouse.y = e.clientY;
    }

    window.addEventListener("mousemove", onMouseMove);

    // ── Animation loop (lerp) ──
    function tick() {
      if (!stalker.classList.contains("show")) {
        running = false;
        return;
      }

      pos.stalker.x += (pos.mouse.x - pos.stalker.x) * 0.12;
      pos.stalker.y += (pos.mouse.y - pos.stalker.y) * 0.12;

      const x = Math.round(pos.stalker.x * 10) / 10;
      const y = Math.round(pos.stalker.y * 10) / 10;

      stalker.style.transform = `translate3d(${x}px, ${y}px, 0)`;

      requestAnimationFrame(tick);
    }

    // Activate (show the circle for the first time)
    function activate() {
      stalker.classList.add("isActive");
      show();
    }

    // If the mouse is already inside the window, activate immediately
    if (document.querySelector("body:hover")) {
      activate();
    } else {
      document.body.addEventListener(
        "mouseenter",
        () => activate(),
        { once: true },
      );
    }

    // ── Hover effect: show "open" text on <a> elements ──
    function isLink(element: Element | null): boolean {
      if (!element) return false;
      if (element.tagName === "A") return true;
      // Check if we're inside an <a>
      return element.closest("a") !== null;
    }

    document.body.addEventListener("mouseover", (e: MouseEvent) => {
      const target = e.target as Element;
      if (isLink(target)) {
        stalker.classList.add("show-text");
      }
    });

    document.body.addEventListener("mouseout", (e: MouseEvent) => {
      const target = e.target as Element;
      if (isLink(target)) {
        // Only remove if we're not entering another link
        const related = (e as any).relatedTarget as Element | null;
        if (related && isLink(related)) return;
        stalker.classList.remove("show-text");
      }
    });
  })();
</script>

<style>
  .mouse-stalker {
    position: fixed;
    top: 0;
    left: 0;
    transform: translate3d(50vw, 50vh, 0);
    z-index: 9999;
    pointer-events: none;
    will-change: transform;
  }

  .mouse-stalker--container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mouse-stalker--circle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.25);
    opacity: 0;
    transition:
      opacity 0.25s ease-out,
      transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
      background 0.3s ease-out,
      border-color 0.3s ease-out,
      width 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
      height 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  /* Visible state */
  .mouse-stalker.isActive.show .mouse-stalker--circle {
    opacity: 1;
  }

  /* Hover over a link */
  .mouse-stalker.show-text .mouse-stalker--circle {
    width: 60px;
    height: 60px;
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .mouse-stalker--text {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
    opacity: 0;
    transform: scale(0.5);
    transition:
      opacity 0.2s ease-out,
      transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    line-height: 1;
  }

  .mouse-stalker.show-text .mouse-stalker--text {
    opacity: 1;
    transform: scale(1);
  }
</style>
