---
// src/components/PillarsSection.astro
// Five Pillars of Prestige + Why Choose Prominent
---

<section id="pillars" class="py-24 md:py-32 bg-black">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Section label -->
    <p
      class="section-label font-['Barlow_Condensed'] text-xs md:text-sm tracking-[0.2em] uppercase text-gray-500 mb-6"
    >
      Why Choose Prominent
    </p>

    <!-- Main heading -->
    <h2
      class="pillars-heading font-['Barlow_Condensed'] font-bold text-white leading-[0.9] tracking-[-0.02em]
             text-[clamp(2.5rem,8vw,5rem)] mb-8 max-w-4xl"
    >
      Built on Trust,<br />
      Delivered with Excellence
    </h2>

    <!-- Intro paragraph -->
    <p
      class="pillars-intro font-['Barlow'] font-light text-gray-400 text-lg md:text-xl leading-relaxed max-w-3xl mb-16 md:mb-20"
    >
      At Prominent, we view each project not just as a building, but as a
      long-term relationship built on trust. From turnkey projects to
      large-scale subcontracting services, we prioritize quality, on-time
      delivery, and a professional business approach in all processes.
    </p>

    <!-- Five Pillars Grid -->
    <div class="pillars-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      <!-- Pillar 1: Architectural Excellence -->
      <div class="pillar-card group">
        <div class="pillar-number font-['Barlow_Condensed'] text-6xl md:text-7xl font-bold text-white/5 select-none leading-none mb-4">
          01
        </div>
        <h3 class="pillar-title font-['Barlow_Condensed'] text-xl md:text-2xl font-bold text-white uppercase tracking-wide mb-3">
          Architectural Excellence
        </h3>
        <p class="pillar-desc font-['Barlow'] font-light text-gray-400 text-sm md:text-base leading-relaxed">
          Combining aesthetics, functionality, and technical expertise to create
          timeless, high-quality structures. Attention to architectural details
          gives our projects a distinct identity.
        </p>
      </div>

      <!-- Pillar 2: Precision Delivery -->
      <div class="pillar-card group">
        <div class="pillar-number font-['Barlow_Condensed'] text-6xl md:text-7xl font-bold text-white/5 select-none leading-none mb-4">
          02
        </div>
        <h3 class="pillar-title font-['Barlow_Condensed'] text-xl md:text-2xl font-bold text-white uppercase tracking-wide mb-3">
          Precision Delivery
        </h3>
        <p class="pillar-desc font-['Barlow'] font-light text-gray-400 text-sm md:text-base leading-relaxed">
          Meticulous management of planning and execution processes to deliver
          projects flawlessly and on schedule. Every timeline is respected,
          every milestone met with precision.
        </p>
      </div>

      <!-- Pillar 3: Refined Finishing -->
      <div class="pillar-card group">
        <div class="pillar-number font-['Barlow_Condensed'] text-6xl md:text-7xl font-bold text-white/5 select-none leading-none mb-4">
          03
        </div>
        <h3 class="pillar-title font-['Barlow_Condensed'] text-xl md:text-2xl font-bold text-white uppercase tracking-wide mb-3">
          Refined Finishing
        </h3>
        <p class="pillar-desc font-['Barlow'] font-light text-gray-400 text-sm md:text-base leading-relaxed">
          The true value of a building lies in the details. We complete every
          project to the highest aesthetic and quality standards using fine
          craftsmanship and superior materials.
        </p>
      </div>

      <!-- Pillar 4: Superior Standards -->
      <div class="pillar-card group">
        <div class="pillar-number font-['Barlow_Condensed'] text-6xl md:text-7xl font-bold text-white/5 select-none leading-none mb-4">
          04
        </div>
        <h3 class="pillar-title font-['Barlow_Condensed'] text-xl md:text-2xl font-bold text-white uppercase tracking-wide mb-3">
          Superior Standards
        </h3>
        <p class="pillar-desc font-['Barlow'] font-light text-gray-400 text-sm md:text-base leading-relaxed">
          Prioritizing quality, safety, and sustainability. Building long-lasting
          structures with solutions that meet international standards and exceed
          expectations.
        </p>
      </div>

      <!-- Pillar 5: Customer Trust -->
      <div class="pillar-card group">
        <div class="pillar-number font-['Barlow_Condensed'] text-6xl md:text-7xl font-bold text-white/5 select-none leading-none mb-4">
          05
        </div>
        <h3 class="pillar-title font-['Barlow_Condensed'] text-xl md:text-2xl font-bold text-white uppercase tracking-wide mb-3">
          Customer Trust
        </h3>
        <p class="pillar-desc font-['Barlow'] font-light text-gray-400 text-sm md:text-base leading-relaxed">
          Building long-term partnerships based on transparent communication and
          mutual trust. We aim to be a reliable solution partner by keeping our
          promises.
        </p>
      </div>

      <!-- Differentiators — spans 2 columns on large -->
      <div class="pillar-card md:col-span-2 lg:col-span-3 border-t border-gray-800 pt-8 md:pt-10 mt-4">
        <h3 class="font-['Barlow_Condensed'] text-lg md:text-xl font-bold text-white uppercase tracking-wide mb-6">
          Our Commitment
        </h3>
        <ul class="differentiators-list grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <li class="flex items-start gap-3 font-['Barlow'] font-light text-gray-400 text-sm md:text-base">
            <span class="text-white/30 mt-1.5 w-1.5 h-1.5 rounded-full bg-gray-600 flex-shrink-0"></span>
            Meticulous project management with an experienced and expert team
          </li>
          <li class="flex items-start gap-3 font-['Barlow'] font-light text-gray-400 text-sm md:text-base">
            <span class="text-white/30 mt-1.5 w-1.5 h-1.5 rounded-full bg-gray-600 flex-shrink-0"></span>
            Strict adherence to schedules with an on-time delivery approach
          </li>
          <li class="flex items-start gap-3 font-['Barlow'] font-light text-gray-400 text-sm md:text-base">
            <span class="text-white/30 mt-1.5 w-1.5 h-1.5 rounded-full bg-gray-600 flex-shrink-0"></span>
            High-standard solutions through quality-focused execution
          </li>
          <li class="flex items-start gap-3 font-['Barlow'] font-light text-gray-400 text-sm md:text-base">
            <span class="text-white/30 mt-1.5 w-1.5 h-1.5 rounded-full bg-gray-600 flex-shrink-0"></span>
            Continuous client communication based on transparent and reliable principles
          </li>
          <li class="flex items-start gap-3 font-['Barlow'] font-light text-gray-400 text-sm md:text-base">
            <span class="text-white/30 mt-1.5 w-1.5 h-1.5 rounded-full bg-gray-600 flex-shrink-0"></span>
            Professional approach to any scale of work, backed by large-scale experience
          </li>
          <li class="flex items-start gap-3 font-['Barlow'] font-light text-gray-400 text-sm md:text-base">
            <span class="text-white/30 mt-1.5 w-1.5 h-1.5 rounded-full bg-gray-600 flex-shrink-0"></span>
            Flawless end-to-end execution through comprehensive turnkey services
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  (function () {
    const section = document.getElementById("pillars");
    if (!section) return;

    // Entrance animation: heading + intro
    gsap.from(".pillars-heading", {
      y: 60,
      opacity: 0,
      duration: 1,
      ease: "power3.out",
      scrollTrigger: {
        trigger: section,
        start: "top 80%",
        toggleActions: "play none none none",
      },
    });

    gsap.from(".pillars-intro", {
      y: 40,
      opacity: 0,
      duration: 1,
      delay: 0.2,
      ease: "power2.out",
      scrollTrigger: {
        trigger: section,
        start: "top 75%",
        toggleActions: "play none none none",
      },
    });

    // Stagger pillar cards
    gsap.from(".pillar-card", {
      y: 50,
      opacity: 0,
      duration: 0.8,
      stagger: 0.1,
      ease: "power2.out",
      scrollTrigger: {
        trigger: section,
        start: "top 70%",
        toggleActions: "play none none none",
      },
    });

    // Differentiators stagger
    gsap.from(".differentiators-list li", {
      y: 20,
      opacity: 0,
      duration: 0.5,
      stagger: 0.05,
      ease: "power1.out",
      scrollTrigger: {
        trigger: ".differentiators-list",
        start: "top 85%",
        toggleActions: "play none none none",
      },
    });
  })();
</script>

<style>
  .pillar-card {
    padding: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
    transition: border-color 0.4s ease, background 0.4s ease;
    will-change: transform;
  }

  .pillar-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.04);
  }

  .differentiators-list li {
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .pillars-heading,
    .pillars-intro,
    .pillar-card,
    .differentiators-list li {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>
