<style>
  .logo-ticker-section {
    background: #0c0c0c;
    padding: 3rem 0;
    overflow: hidden;
  }

  .ticker-container {
    max-width: 100%;
    margin: 0 auto;
  }

  .ticker-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    text-align: center;
    margin: 0 0 2rem;
  }

  .ticker-track {
    overflow: hidden;
    width: 100%;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 5%,
      black 95%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 5%,
      black 95%,
      transparent 100%
    );
  }

  .ticker-content {
    display: flex;
    gap: 4rem;
    width: max-content;
    animation: ticker-scroll 140s linear infinite;
    will-change: transform;
  }

  .ticker-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: calc((100vw - 4rem * 4) / 5);
  }

  .ticker-item svg {
    width: 100%;
    height: auto;
    max-height: 3rem;
    color: #999999;
    fill: currentColor;
  }

  @keyframes ticker-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 1023px) {
    .ticker-content {
      gap: 3rem;
    }
    .ticker-item {
      width: calc((100vw - 3rem * 2) / 3);
    }
    .ticker-item svg {
      max-height: 2.5rem;
    }
  }

  @media (max-width: 767px) {
    .ticker-content {
      gap: 2rem;
    }
    .ticker-item {
      width: calc((100vw - 2rem * 1) / 2);
    }
    .ticker-item svg {
      max-height: 2rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ticker-content {
      animation: none;
    }
  }
</style>