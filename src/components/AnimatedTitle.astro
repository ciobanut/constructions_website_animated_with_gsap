---
export interface Props {
	text: string;
}

const { text } = Astro.props;
const chars = text.split('');
---

<h1 class="animated-title" aria-label={text}>
	{
		chars.map((char, i) => (
			<span class="char-wrapper" data-index={i}>
				<span class="char">{char === ' ' ? ' ' : char}</span>
			</span>
		))
	}
</h1>

<script>
	import { gsap } from 'gsap';

	const wrappers = document.querySelectorAll<HTMLElement>('.char-wrapper');
	const charSpans = document.querySelectorAll<HTMLElement>('.char');
	const title = document.querySelector<HTMLElement>('.animated-title')!;
	const total = wrappers.length;
	const SPREAD = 4;

	wrappers.forEach((wrapper, hoveredIdx) => {
		wrapper.addEventListener('mouseenter', () => {
			const height = charSpans[hoveredIdx].offsetHeight;
			const maxLift = height * 0.30;

			charSpans.forEach((span, i) => {
				const dist = Math.abs(i - hoveredIdx);
				const factor = Math.max(0, 1 - dist / SPREAD);
				const lift = maxLift * factor;

				gsap.to(span, {
					y: -lift,
					duration: 0.35,
					ease: 'back.out(1.7)',
					overwrite: 'auto',
				});
			});
		});
	});

	title.addEventListener('mouseleave', () => {
		charSpans.forEach((span) => {
			gsap.to(span, {
				y: 0,
				duration: 0.25,
				ease: 'power2.out',
				overwrite: 'auto',
			});
		});
	});
</script>

<style>
	.animated-title {
		display: inline-flex;
		flex-wrap: wrap;
		justify-content: center;
		margin: 0;
		font-size: clamp(2.5rem, 8vw, 5.5rem);
		font-weight: 700;
		font-family: 'Barlow Condensed', sans-serif;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		text-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
	}

	.char-wrapper {
		display: inline-block;
		position: relative;
		cursor: default;
	}

	.char {
		display: inline-block;
		position: relative;
		will-change: transform;
	}
</style>
