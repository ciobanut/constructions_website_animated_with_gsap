---
/**
 * ProjectThumbnail.astro
 * Renders a single project thumbnail positioned on the map.
 * Coordinates are percentage-based relative to the SVG.
 */
import type { ProjectMapData } from "./types";

interface Props {
  project: ProjectMapData;
}

const { project } = Astro.props;
---

<div
  class="project-thumb"
  data-project-slug={project.slug}
  style={`left: ${project.map.x}%; top: ${project.map.y}%;`}
>
  <img
    src={project.coverImage}
    alt={project.title}
    class="thumb-image"
    loading="lazy"
    decoding="async"
  />
  <div class="thumb-label">
    <span class="thumb-title">{project.title}</span>
  </div>
</div>

<style>
  .project-thumb {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 140px;
    height: 100px;
    border-radius: 10px;
    overflow: hidden;
    border: 2px solid rgba(255, 255, 255, 0.25);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
    cursor: pointer;
    z-index: 10;
    will-change: transform, opacity;
    transition: box-shadow 0.3s ease;
  }

  .project-thumb:hover {
    box-shadow: 0 8px 32px rgba(255, 255, 255, 0.1);
    z-index: 20;
  }

  .thumb-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .thumb-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
    padding: 6px 8px 4px;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .project-thumb:hover .thumb-label {
    opacity: 1;
  }

  .thumb-title {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 11px;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.2;
  }

  @media (max-width: 768px) {
    .project-thumb {
      width: 110px;
      height: 78px;
      border-radius: 8px;
      border-width: 1.5px;
    }

    .thumb-title {
      font-size: 9px;
    }
  }
</style>
