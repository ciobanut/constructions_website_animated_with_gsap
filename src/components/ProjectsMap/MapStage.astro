---
/**
 * MapStage.astro
 * Wrapper for the SVG map. Handles the map container that gets
 * transformed by GSAP (translate + scale).
 */
interface Props {
  mapPath: string;
}

const { mapPath } = Astro.props;
---

<div class="map-stage" data-map-stage>
  <div class="map-container" data-map-container>
    <img
      src={mapPath}
      alt="Middle East map"
      class="map-svg"
      loading="eager"
      fetchpriority="high"
    />
  </div>
</div>

<style>
  .map-stage {
    position: absolute;
    inset: 0;
    overflow: hidden;
    will-change: transform;
  }

  .map-container {
    width: 100%;
    height: 100%;
    transform-origin: center center;
    will-change: transform;
  }

  .map-svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
    user-select: none;
    pointer-events: none;
  }
</style>
