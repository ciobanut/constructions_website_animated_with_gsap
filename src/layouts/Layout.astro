---
import CustomCursor from "../components/CustomCursor.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import NavBar from "../components/NavBar.astro";
---
<!doctype html>
<html lang="en" class="bg-[#0c0c0c]">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Prominent For Design &amp; Construction</title>
		<!-- Hero video preload — high priority -->
		<link rel="preload" as="video" href="/video-bg.webm" fetchpriority="high" type="video/webm" />
		<link rel="preload" as="video" href="/video-bg.mp4" fetchpriority="high" type="video/mp4" />
		<!-- Hero poster (shown instantly, replaces video as LCP content) -->
		<link rel="preload" as="image" href="/images/hero-bg.avif" fetchpriority="high" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;700&family=Barlow:wght@300;400&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<NavBar />
<slot />
		<CustomCursor />
		<WhatsAppButton />
	</body>
</html>

<style is:global>
	@import "tailwindcss";
	@plugin "@tailwindcss/typography";
</style>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family: 'Barlow', sans-serif;
		background: #0c0c0c;
		color: #e5e5e5;
	}
</style>
