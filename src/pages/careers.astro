---
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <title>Careers | Prominent</title>
  <meta name="description" content="Join the Prominent team. Explore career opportunities in construction, design, and project management." />

  <NavBar />

  <main class="z-10 relative bg-black min-h-screen">
    <!-- Hero -->
    <section class="relative pt-36 pb-16 md:pt-44 md:pb-20 px-6">
      <div class="max-w-7xl mx-auto">
        <p class="font-['Barlow_Condensed'] text-xs md:text-sm tracking-[0.2em] uppercase text-gray-500 mb-6">
          Careers
        </p>
        <h1 class="font-['Barlow_Condensed'] font-bold text-white leading-[0.9] tracking-[-0.02em] text-[clamp(3rem,12vw,10rem)]">
          Join<br />Our Team
        </h1>
      </div>
    </section>

    <!-- Content -->
    <section class="pb-24 md:pb-32 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="max-w-2xl">
          <p class="font-['Barlow'] text-lg md:text-xl text-gray-300 leading-relaxed mb-8 border-l-2 border-gray-700 pl-6">
            We're always looking for talented individuals who share our passion
            for quality construction and architectural excellence.
          </p>

          <div class="p-8 md:p-10 border border-white/10 rounded-xl bg-white/[0.02] text-center">
            <div class="w-16 h-16 rounded-full bg-white/5 flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
              </svg>
            </div>
            <h2 class="font-['Barlow_Condensed'] text-2xl font-bold text-white uppercase tracking-wide mb-4">
              We're Hiring — Check Back Soon
            </h2>
            <p class="font-['Barlow'] font-light text-gray-400 leading-relaxed mb-6">
              We are currently reviewing our staffing needs and will be posting
              open positions soon. If you'd like to be notified when new
              opportunities become available, feel free to reach out to us.
            </p>
            <a
              href="mailto:34prominent@gmail.com"
              class="inline-block font-['Barlow_Condensed'] text-sm uppercase tracking-[0.15em] text-white/70 hover:text-white border-b border-white/20 hover:border-white transition-all duration-300 pb-1"
            >
              Contact us →
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  import { gsap } from "gsap";
  gsap.from("main", { y: 40, opacity: 0, duration: 0.8, ease: "power2.out" });
  gsap.from("h1", { y: 60, opacity: 0, duration: 1, delay: 0.2, ease: "power3.out" });
  gsap.from(".border-l-2", { y: 30, opacity: 0, duration: 0.8, delay: 0.4, ease: "power2.out" });
</script>
