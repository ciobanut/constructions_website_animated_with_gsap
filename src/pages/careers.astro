---
import Layout from "../layouts/Layout.astro";

import Footer from "../components/Footer.astro";
import Button from "../components/ui/Button.astro";
---

<Layout>
  <title>Careers | Prominent</title>
  <meta name="description" content="Join the Prominent team. Explore career opportunities in construction, design, and project management." />



  <main class="z-10 relative bg-black min-h-screen">
    <!-- Hero -->
    <section class="relative pt-36 pb-16 md:pt-44 md:pb-20 px-6">
      <div class="max-w-7xl mx-auto">
        <p class="font-['Barlow_Condensed'] text-xs md:text-sm tracking-[0.2em] uppercase text-gray-500 mb-6">
          Careers
        </p>
        <h1 class="font-['Barlow_Condensed'] font-bold text-white leading-[0.9] tracking-[-0.02em] text-[clamp(3rem,12vw,10rem)]">
          Join<br />Our Team
        </h1>
      </div>
    </section>

    <!-- Intro -->
    <section class="pb-16 md:pb-24 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="max-w-3xl">
          <p class="font-['Barlow'] text-lg md:text-xl text-gray-300 leading-relaxed border-l-2 border-gray-700 pl-6">
            We're always looking for talented individuals who share our passion
            for quality construction and architectural excellence. At Prominent,
            every team member plays a vital role in bringing our projects to life.
          </p>
        </div>
      </div>
    </section>

    <!-- Why Join Prominent / Benefits -->
    <section class="benefits-section py-20 md:py-28 px-6 bg-[#0c0c0c]">
      <div class="max-w-7xl mx-auto">
        <p class="font-['Barlow_Condensed'] text-xs md:text-sm tracking-[0.2em] uppercase text-gray-500 mb-6">
          Why Join Us
        </p>
        <h2 class="font-['Barlow_Condensed'] font-bold text-white leading-[0.9] tracking-[-0.02em] text-[clamp(2rem,6vw,4rem)] mb-12 max-w-3xl">
          Build Your Career With Prominent
        </h2>

        <div class="benefits-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="benefit-card p-6 border border-white/10 rounded-xl bg-white/[0.02]">
            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
              </svg>
            </div>
            <h3 class="font-['Barlow_Condensed'] text-lg font-bold text-white uppercase tracking-wide mb-2">
              Meaningful Projects
            </h3>
            <p class="font-['Barlow'] font-light text-gray-400 text-sm leading-relaxed">
              Work on impactful residential, commercial, and institutional projects
              that shape communities and stand the test of time.
            </p>
          </div>

          <div class="benefit-card p-6 border border-white/10 rounded-xl bg-white/[0.02]">
            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
              </svg>
            </div>
            <h3 class="font-['Barlow_Condensed'] text-lg font-bold text-white uppercase tracking-wide mb-2">
              Expert Team Environment
            </h3>
            <p class="font-['Barlow'] font-light text-gray-400 text-sm leading-relaxed">
              Collaborate with seasoned professionals who bring decades of combined
              experience in architecture, engineering, and construction management.
            </p>
          </div>

          <div class="benefit-card p-6 border border-white/10 rounded-xl bg-white/[0.02]">
            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="16 18 22 12 16 6" />
                <polyline points="8 6 2 12 8 18" />
              </svg>
            </div>
            <h3 class="font-['Barlow_Condensed'] text-lg font-bold text-white uppercase tracking-wide mb-2">
              Professional Growth
            </h3>
            <p class="font-['Barlow'] font-light text-gray-400 text-sm leading-relaxed">
              We invest in our people through continuous learning opportunities,
              hands-on experience, and clear paths for career advancement.
            </p>
          </div>

          <div class="benefit-card p-6 border border-white/10 rounded-xl bg-white/[0.02]">
            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
            </div>
            <h3 class="font-['Barlow_Condensed'] text-lg font-bold text-white uppercase tracking-wide mb-2">
              Quality-Driven Culture
            </h3>
            <p class="font-['Barlow'] font-light text-gray-400 text-sm leading-relaxed">
              Join a team that takes pride in superior craftsmanship, safety standards,
              and delivering projects that exceed expectations.
            </p>
          </div>

          <div class="benefit-card p-6 border border-white/10 rounded-xl bg-white/[0.02]">
            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
                <line x1="8" y1="21" x2="16" y2="21" />
                <line x1="12" y1="17" x2="12" y2="21" />
              </svg>
            </div>
            <h3 class="font-['Barlow_Condensed'] text-lg font-bold text-white uppercase tracking-wide mb-2">
              Stability & Trust
            </h3>
            <p class="font-['Barlow'] font-light text-gray-400 text-sm leading-relaxed">
              With over 17 years of industry presence and 27+ completed projects,
              Prominent offers a stable, trustworthy workplace you can rely on.
            </p>
          </div>

          <div class="benefit-card p-6 border border-white/10 rounded-xl bg-white/[0.02]">
            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
                <line x1="12" y1="22.08" x2="12" y2="12" />
              </svg>
            </div>
            <h3 class="font-['Barlow_Condensed'] text-lg font-bold text-white uppercase tracking-wide mb-2">
              Comprehensive Benefits
            </h3>
            <p class="font-['Barlow'] font-light text-gray-400 text-sm leading-relaxed">
              We offer competitive compensation, a supportive work environment,
              and the resources you need to perform at your best.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Open Positions -->
    <section class="positions-section py-20 md:py-28 px-6">
      <div class="max-w-7xl mx-auto">
        <p class="font-['Barlow_Condensed'] text-xs md:text-sm tracking-[0.2em] uppercase text-gray-500 mb-6">
          Open Positions
        </p>
        <h2 class="font-['Barlow_Condensed'] font-bold text-white leading-[0.9] tracking-[-0.02em] text-[clamp(2rem,6vw,4rem)] mb-6 max-w-3xl">
          Current Opportunities
        </h2>
        <p class="font-['Barlow'] font-light text-gray-400 leading-relaxed max-w-2xl mb-12">
          We are currently reviewing our staffing needs and will be posting open
          positions here as they become available.
        </p>

        <!-- Empty state card (shown when no positions are listed) -->
        <div class="positions-empty p-8 md:p-10 border border-white/10 rounded-xl bg-white/[0.02] text-center max-w-2xl mx-auto">
          <div class="w-16 h-16 rounded-full bg-white/5 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
              <circle cx="12" cy="7" r="4" />
            </svg>
          </div>
          <h3 class="font-['Barlow_Condensed'] text-2xl font-bold text-white uppercase tracking-wide mb-4">
            No Open Positions At This Time
          </h3>
          <p class="font-['Barlow'] font-light text-gray-400 leading-relaxed mb-6">
            We don't have any open roles right now, but we're always interested
            in connecting with talented professionals. Send us your CV and we'll
            keep you in mind for future opportunities.
          </p>
          <Button variant="filled" href="mailto:34prominent@gmail.com?subject=Job%20Inquiry%20-%20[Your%20Position]">
            Send Your CV
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="7" y1="17" x2="17" y2="7" />
              <polyline points="7 7 17 7 17 17" />
            </svg>
          </Button>
        </div>

        <!--
          Job listing grid template — uncomment when positions are available:
          <div class="positions-grid grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="job-card p-6 border border-white/10 rounded-xl bg-white/[0.02]">
              <div class="flex items-start justify-between gap-4 mb-4">
                <h3 class="font-['Barlow_Condensed'] text-lg font-bold text-white uppercase tracking-wide">Job Title</h3>
                <span class="font-['Barlow_Condensed'] text-xs uppercase tracking-wider text-gray-500 bg-white/5 px-3 py-1 rounded-full whitespace-nowrap">Full-time</span>
              </div>
              <p class="font-['Barlow'] font-light text-gray-400 text-sm leading-relaxed mb-5">Description...</p>
              <a href="mailto:34prominent@gmail.com?subject=Application%20-%20Job%20Title"
                 class="font-['Barlow_Condensed'] text-sm uppercase tracking-[0.08em] text-white/70 hover:text-white border-b border-white/20 hover:border-white transition-all duration-300 ease-out pb-1">
                Apply now →
              </a>
            </div>
          </div>
        -->
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section py-20 md:py-28 px-6 bg-[#0c0c0c]">
      <div class="max-w-7xl mx-auto">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="font-['Barlow_Condensed'] font-bold text-white leading-[0.9] tracking-[-0.02em] text-[clamp(2rem,5vw,3.5rem)] mb-6">
            Don't See the Right Role?
          </h2>
          <p class="font-['Barlow'] font-light text-gray-400 text-lg leading-relaxed mb-10">
            We're always on the lookout for passionate individuals. Send us your
            CV and a brief note about what you do — we'll reach out if a suitable
            position opens up.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <Button variant="filled" href="mailto:34prominent@gmail.com?subject=Application%20-%20[Your%20Position]">
              Submit Your Application
            </Button>
            <Button variant="whatsapp-outline" href="https://wa.me/9647501226498" target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
              </svg>
              Message on WhatsApp
            </Button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // Entrance animations
  gsap.from("main", { y: 40, opacity: 0, duration: 0.8, ease: "power2.out" });
  gsap.from("h1", { y: 60, opacity: 0, duration: 1, delay: 0.2, ease: "power3.out" });
  gsap.from(".border-l-2", { y: 30, opacity: 0, duration: 0.8, delay: 0.4, ease: "power2.out" });

  // Benefits — scroll-triggered stagger
  gsap.from(".benefit-card", {
    y: 50,
    opacity: 0,
    duration: 0.8,
    stagger: 0.12,
    ease: "power2.out",
    scrollTrigger: {
      trigger: ".benefits-grid",
      start: "top 80%",
    },
  });

  // Positions empty state — scroll-triggered
  gsap.from(".positions-empty", {
    y: 40,
    opacity: 0,
    duration: 0.8,
    ease: "power2.out",
    scrollTrigger: {
      trigger: ".positions-empty",
      start: "top 85%",
    },
  });

  // CTA section — scroll-triggered
  gsap.from(".cta-section h2", {
    y: 40,
    opacity: 0,
    duration: 0.8,
    ease: "power2.out",
    scrollTrigger: {
      trigger: ".cta-section",
      start: "top 80%",
    },
  });
  gsap.from(".cta-section p", {
    y: 30,
    opacity: 0,
    duration: 0.8,
    delay: 0.15,
    ease: "power2.out",
    scrollTrigger: {
      trigger: ".cta-section",
      start: "top 80%",
    },
  });
  gsap.from(".cta-section .flex", {
    y: 20,
    opacity: 0,
    duration: 0.6,
    delay: 0.3,
    ease: "power2.out",
    scrollTrigger: {
      trigger: ".cta-section",
      start: "top 80%",
    },
  });

  // Cleanup on page leave
  document.addEventListener("astro:before-swap", () => {
    ScrollTrigger.getAll().forEach((st) => st.kill());
  });
</script>
