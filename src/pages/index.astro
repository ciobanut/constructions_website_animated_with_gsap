---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import AnimatedTitle from "../components/AnimatedTitle.astro";
import StatsSection from "../components/StatsSection.astro";
import ServicesSection from "../components/ServicesSection.astro";
import HorizontalGallery from "../components/HorizontalGallery.astro";
import LogoTicker from "../components/LogoTicker.astro";
import TestimonialVideo from "../components/TestimonialVideo.astro";
import PillarsSection from "../components/PillarsSection.astro";

const title = "Prominent";
const subtitle = "We add value to buildings, we add trust to projects";
const projects = await getCollection("projects");
const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Layout>
  <!-- NavBar floating above hero -->
  <NavBar />

  <main class="main-content z-10 relative">
    <!-- Hero Section -->
    <section id="home" class="hero">
      <!-- Video background — multi-format sources with poster fallback -->
      <div class="video-wrapper">
        <video
          id="hero-video"
          class="hero__media hero__media--video"
          poster="/images/hero-bg.avif"
          autoplay
          loop
          muted
          playsinline
          preload="metadata"
          fetchpriority="high"
        >
          <source src="/video-bg.webm" type="video/webm">
          <source src="/video-bg.mp4" type="video/mp4">
        </video>
      </div>

      <!-- Dark overlay for readability -->
      <div class="overlay"></div>

      <!-- Hero content -->
      <div class="content">
        <AnimatedTitle text={title} />
        <p class="subtitle">{subtitle}</p>
      </div>
    </section>

    

    <HorizontalGallery projects={projects} />

    <StatsSection />

    <ServicesSection services={services} />

    <PillarsSection />

    <LogoTicker />

    <TestimonialVideo />
  </main>

  <Footer />
</Layout>

<script>
  import { gsap } from "gsap";

  // --- Title animations ---
  gsap.from(".animated-title .char", {
    y: 60,
    opacity: 0,
    duration: 0.8,
    stagger: 0.04,
    ease: "power3.out",
  });
  gsap.from(".subtitle", {
    y: 30,
    opacity: 0,
    duration: 1,
    delay: 0.4,
    ease: "power3.out",
  });
</script>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100dvh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .video-wrapper {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .video-wrapper video,
  .video-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    object-fit: cover;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.55),
      rgba(0, 0, 0, 0.3)
    );
    z-index: 1;
  }

  .content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: white;
    padding: 0 24px;
  }

  .subtitle {
    font-size: clamp(1rem, 2.5vw, 1.5rem);
    font-weight: 300;
    font-family: "Barlow", sans-serif;
    margin: 16px 0 0;
    opacity: 0.9;
    letter-spacing: 0.06em;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.3);
  }
</style>
