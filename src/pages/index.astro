---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import AnimatedTitle from "../components/AnimatedTitle.astro";
import StatsSection from "../components/StatsSection.astro";
import ServicesSection from "../components/ServicesSection.astro";
import HorizontalGallery from "../components/HorizontalGallery.astro";
import LogoTicker from "../components/LogoTicker.astro";
import TestimonialVideo from "../components/TestimonialVideo.astro";
import PillarsSection from "../components/PillarsSection.astro";

const title = "Prominent";
const subtitle = "We add value to buildings, we add trust to projects";
const projects = await getCollection("projects");
const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Layout>
  <!-- NavBar floating above hero -->
  <NavBar />

  <main class="main-content z-10 relative">
    <!-- Hero Section -->
    <section id="home" class="hero">
      <!-- YouTube video background -->
      <div class="video-wrapper">
        <video class="hero__media hero__media--video" src="https://www.bechtel.com/wp-content/uploads/2024/10/d87d-4b9c-b68c-117a0309cbf8.mp4" poster="" autoplay="" loop="" muted="" playsinline="" preload="auto" data-dynamic-id="csp-6318a942877f"></video>
      </div>

      <!-- Fallback image — shown while video loads, then faded out via GSAP -->
      <img
        id="hero-fallback"
        src="/images/hero-bg.avif"
        alt=""
        class="hero-fallback"
      />

      <!-- Dark overlay for readability -->
      <div class="overlay"></div>

      <!-- Hero content -->
      <div class="content">
        <AnimatedTitle text={title} />
        <p class="subtitle">{subtitle}</p>
      </div>
    </section>

    

    <HorizontalGallery projects={projects} />

    <StatsSection />

    <ServicesSection services={services} />

    <PillarsSection />

    <LogoTicker />

    <TestimonialVideo />
  </main>

  <Footer />
</Layout>

<script>
  import { gsap } from "gsap";

  // --- Hero image → video transition (slow zoom-out, accelerates on video ready) ---
  const fallback = document.getElementById("hero-fallback");
  const iframe = document.querySelector(".video-wrapper iframe");

  if (fallback) {
    let transitionStarted = false;

    // Slow zoom-out starts immediately on page load (image starts at scale 1.1)
    gsap.fromTo(
      fallback,
      { scale: 1.1 },
      {
        scale: 1.0,
        duration: 6,
        ease: "none",
        onComplete: () => {
          // Restart video from 0:00 so it feels like it starts fresh
          (iframe as HTMLIFrameElement)?.contentWindow?.postMessage(
            JSON.stringify({
              event: "command",
              func: "seekTo",
              args: [0, true],
            }),
            "https://www.youtube.com",
          );
        },
      },
    );

    function accelerateTransition() {
      if (transitionStarted) return;
      transitionStarted = true;

      // Interrupt the slow tween: fast zoom-out completion + fade to 0
      gsap.to(fallback, {
        scale: 1.0,
        opacity: 0,
        duration: 1,
        ease: "power2.inOut",
        overwrite: "auto",
        onComplete: () => {
          fallback?.remove();
        },
      });
    }

    // Safety: force fade after 6s (matches slow-tween duration)
    setTimeout(accelerateTransition, 6000);

    // YouTube Player API: accelerate when video starts playing
    window.addEventListener("message", (event) => {
      if (
        event.origin === "https://www.youtube.com" &&
        event.data &&
        event.data.event === "onStateChange" &&
        event.data.info === 1 // YT.PlayerState.PLAYING
      ) {
        accelerateTransition();
      }
    });
  }

  // --- Title animations (unchanged) ---
  gsap.from(".animated-title .char", {
    y: 60,
    opacity: 0,
    duration: 0.8,
    stagger: 0.04,
    ease: "power3.out",
  });
  gsap.from(".subtitle", {
    y: 30,
    opacity: 0,
    duration: 1,
    delay: 0.4,
    ease: "power3.out",
  });
</script>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .video-wrapper {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .video-wrapper iframe {
    width: 100%;
    height: 100%;
    border: 0;
    /* Crop to cover like object-fit: cover */
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 177.78vh;
    /* 16:9 aspect-ratio height-relative */
    height: 56.25vw;
    /* 16:9 aspect-ratio width-relative */
    min-width: 100%;
    min-height: 100%;
  }

  .hero-fallback {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    will-change: transform, opacity;
    transform: scale(1.1);
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.55),
      rgba(0, 0, 0, 0.3)
    );
    z-index: 1;
  }

  .content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: white;
    padding: 0 24px;
  }

  .subtitle {
    font-size: clamp(1rem, 2.5vw, 1.5rem);
    font-weight: 300;
    font-family: "Barlow", sans-serif;
    margin: 16px 0 0;
    opacity: 0.9;
    letter-spacing: 0.06em;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.3);
  }
</style>
