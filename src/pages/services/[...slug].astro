---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import NavBar from "../../components/NavBar.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const services = await getCollection("services");
  return services.map((service) => ({
    params: { slug: service.data.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);
const { data } = service;
const pageTitle = `${data.title} | Prominent`;
---

<Layout>
  <title>{pageTitle}</title>
  <meta name="description" content={data.shortDescription} />

  <NavBar />

  <main class="z-10 relative bg-black min-h-screen">
    <!-- Hero area with massive service title -->
    <section class="relative pt-36 pb-16 md:pt-44 md:pb-20 px-6">
      <div class="max-w-7xl mx-auto">
        <!-- Breadcrumb back link -->
        <a
          href="/#services-section"
          class="inline-flex items-center gap-2 font-['Barlow_Condensed'] text-sm tracking-[0.15em] uppercase
                 text-gray-500 hover:text-white transition-colors duration-300 mb-8 md:mb-10"
        >
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 6l-6 6l6 6" />
          </svg>
          Back to Home
        </a>

        <!-- Massive service title -->
        <h1
          class="font-['Barlow_Condensed'] font-bold text-white leading-[0.85] tracking-[-0.02em]
                 text-[clamp(3rem,12vw,10rem)]"
        >
          {data.title}
        </h1>
      </div>
    </section>

    <!-- Description content -->
    <section class="pb-24 md:pb-32 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="max-w-3xl">
          <!-- Short description as lead -->
          <p
            class="font-['Barlow'] text-lg md:text-xl text-gray-300 leading-relaxed mb-10
                   border-l-2 border-gray-700 pl-6"
          >
            {data.shortDescription}
          </p>

          <!-- Full description -->
          <div
            class="prose prose-invert prose-lg max-w-none
                   prose-p:text-gray-400 prose-p:leading-relaxed prose-p:font-['Barlow'] prose-p:font-light"
          >
            <Content />
          </div>

          <!-- CTA -->
          <div class="mt-12 pt-12 border-t border-gray-800">
            <a
              href="/#services-section"
              class="inline-block font-['Barlow_Condensed'] text-base tracking-[0.15em] uppercase
                     text-white/70 hover:text-white border-b border-white/20 hover:border-white
                     transition-all duration-300 pb-1"
            >
              ← All Services
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  import { gsap } from "gsap";

  // Entrance animation
  gsap.from("main", {
    y: 40,
    opacity: 0,
    duration: 0.8,
    ease: "power2.out",
  });

  gsap.from("h1", {
    y: 60,
    opacity: 0,
    duration: 1,
    delay: 0.2,
    ease: "power3.out",
  });

  gsap.from(".border-l-2", {
    y: 30,
    opacity: 0,
    duration: 0.8,
    delay: 0.4,
    ease: "power2.out",
  });

  gsap.from(".prose", {
    y: 20,
    opacity: 0,
    duration: 0.8,
    delay: 0.5,
    ease: "power2.out",
  });
</script>
